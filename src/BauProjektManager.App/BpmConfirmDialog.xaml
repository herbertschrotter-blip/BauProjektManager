<Window x:Class="BauProjektManager.App.BpmConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BpmDialogWindow}"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <StackPanel Grid.Row="0" Margin="24,24,24,16" Orientation="Horizontal">
            <TextBlock x:Name="TxtIcon" FontSize="28"
                       VerticalAlignment="Top" Margin="0,0,16,0"/>
            <TextBlock x:Name="TxtMessage"
                       Foreground="{DynamicResource BpmTextPrimary}"
                       FontSize="13" TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       MaxWidth="320"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="1" Style="{StaticResource BpmDialogFooter}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Abbrechen"
                        Style="{DynamicResource BpmButtonSecondary}"
                        MinWidth="80" Margin="0,0,8,0"
                        Click="OnCancelClick" IsCancel="True"/>
                <Button Content="Ja"
                        Style="{DynamicResource BpmButtonPrimary}"
                        MinWidth="80"
                        Click="OnYesClick" IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
