<Window x:Class="BauProjektManager.App.BpmInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BpmBgBase}"
        Foreground="{DynamicResource BpmTextPrimary}"
        FontFamily="{DynamicResource BpmFontFamily}"
        FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <StackPanel Grid.Row="0" Margin="24,24,24,16" Orientation="Horizontal">
            <TextBlock x:Name="TxtIcon" FontSize="28"
                       Foreground="{DynamicResource BpmTextPrimary}"
                       VerticalAlignment="Top" Margin="0,0,16,0"/>
            <TextBlock x:Name="TxtMessage"
                       Foreground="{DynamicResource BpmTextPrimary}"
                       FontSize="13" TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       MaxWidth="320"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{DynamicResource BpmBgSurface}"
                BorderBrush="{DynamicResource BpmBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button Content="OK"
                    Style="{DynamicResource BpmButtonPrimary}"
                    MinWidth="80" HorizontalAlignment="Right"
                    Click="OnOkClick" IsDefault="True"/>
        </Border>
    </Grid>
</Window>
