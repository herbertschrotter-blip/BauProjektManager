<Window x:Class="BauProjektManager.App.DevToolsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dev Tools [DEBUG]"
        Width="700" Height="680"
        MinWidth="600" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BpmBgBase}"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="{StaticResource BpmBgBase}"
                    BorderBrush="{StaticResource BpmBorderDefault}">

            <!-- TAB 1: SYSTEM-INFO -->
            <TabItem Header="📋 System-Info" Style="{StaticResource BpmTabItem}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource BpmBgElevated}"
                            CornerRadius="4" Margin="0,0,0,16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="App-Version" Style="{StaticResource BpmLabel}" Padding="12,8" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtAppVersion" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text=".NET Runtime" Style="{StaticResource BpmLabel}" Padding="12,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtRuntime" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Windows" Style="{StaticResource BpmLabel}" Padding="12,8" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtWindows" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Background="{StaticResource BpmBgSurface}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Rechner" Style="{StaticResource BpmLabel}" Padding="12,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtMachine" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="DPI-Skalierung" Style="{StaticResource BpmLabel}" Padding="12,8" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtDpi" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Datenbank" Style="{StaticResource BpmLabel}" Padding="12,8"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtDbPath" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Foreground="{StaticResource BpmAccentPrimary}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="DB-Größe" Style="{StaticResource BpmLabel}" Padding="12,8" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TxtDbSize" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Freier Speicher" Style="{StaticResource BpmLabel}" Padding="12,8"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TxtFreeSpace" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Einstellungen" Style="{StaticResource BpmLabel}" Padding="12,8" Background="{StaticResource BpmBgSurface}"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" x:Name="TxtSettingsPath" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Foreground="{StaticResource BpmAccentPrimary}" Background="{StaticResource BpmBgSurface}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="9" Grid.Column="0" Text="Log-Verzeichnis" Style="{StaticResource BpmLabel}" Padding="12,8"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" x:Name="TxtLogPath" Style="{StaticResource BpmSmallText}" Padding="12,8" FontFamily="Consolas" Foreground="{StaticResource BpmAccentPrimary}" TextWrapping="Wrap"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <Button Content="📋 System-Info + Log kopieren"
                                Style="{StaticResource BpmButtonSecondary}"
                                Click="OnCopyBugReport" Margin="0,0,8,0"/>
                        <Button Content="📂 Log-Ordner öffnen"
                                Style="{StaticResource BpmButtonSecondary}"
                                Click="OnOpenLogs"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 2: LOG -->
            <TabItem Header="📄 Log" Style="{StaticResource BpmTabItem}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Letzte 200 Zeilen" Style="{StaticResource BpmLabel}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="📋 Kopieren" Style="{StaticResource BpmButtonSecondary}" Click="OnCopyLog" Margin="0,0,8,0"/>
                            <Button Content="↻ Aktualisieren" Style="{StaticResource BpmButtonSecondary}" Click="OnRefreshLog"/>
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1"
                            Background="{StaticResource BpmBgElevated}"
                            CornerRadius="4"
                            BorderBrush="{StaticResource BpmBorderDefault}"
                            BorderThickness="1">
                        <ScrollViewer x:Name="LogScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtLogContent"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource BpmTextPrimary}"
                                       Background="Transparent"
                                       Padding="12" TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB 3: RESET -->
            <TabItem Header="🗑 Reset" Style="{StaticResource BpmTabItem}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Was soll zurückgesetzt werden?"
                               Style="{StaticResource BpmHeading3}"
                               Margin="0,0,0,16"/>

                    <StackPanel Grid.Row="1">

                        <!-- Option 1: Nur Ersteinrichtung — GRÜN -->
                        <Border x:Name="BorderFirstRun"
                                Background="{StaticResource BpmBgElevated}"
                                BorderBrush="{StaticResource BpmAccentPrimary}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,12" Margin="0,0,0,10"
                                Cursor="Hand" MouseLeftButtonDown="OnSelectReset" Tag="FirstRun">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="DotFirstRun" Grid.Column="0"
                                         Width="12" Height="12"
                                         Fill="{StaticResource BpmAccentPrimary}"
                                         VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Nur Ersteinrichtung" Style="{StaticResource BpmBodyBold}"/>
                                    <TextBlock Text="Ersteinrichtungs-Dialog erscheint beim nächsten Start. Daten und Pfade bleiben erhalten."
                                               Style="{StaticResource BpmSmallText}" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="settings.json → isFirstRun: true"
                                               FontFamily="Consolas" FontSize="10" Foreground="{StaticResource BpmTextSecondary}"/>
                                </StackPanel>
                                <Border Grid.Column="2"
                                        Background="{StaticResource BpmBadgeBgSuccess}"
                                        BorderBrush="{StaticResource BpmSuccess}"
                                        BorderThickness="1" CornerRadius="10" Padding="8,4">
                                    <TextBlock Text="sicher" FontSize="10"
                                               Foreground="{StaticResource BpmSuccess}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Option 2: Nur Datenbank — GELB -->
                        <Border x:Name="BorderDbOnly"
                                Background="{StaticResource BpmBgElevated}"
                                BorderBrush="{StaticResource BpmBorderDefault}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,12" Margin="0,0,0,10"
                                Cursor="Hand" MouseLeftButtonDown="OnSelectReset" Tag="DbOnly">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="DotDbOnly" Grid.Column="0"
                                         Width="12" Height="12"
                                         Fill="Transparent"
                                         Stroke="{StaticResource BpmTextSecondary}" StrokeThickness="2"
                                         VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Nur Datenbank" Style="{StaticResource BpmBodyBold}"/>
                                    <TextBlock Text="Löscht alle Projektdaten. Einstellungen und Pfade bleiben erhalten."
                                               Style="{StaticResource BpmSmallText}" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="bpm.db · bpm.db-wal · bpm.db-shm"
                                               FontFamily="Consolas" FontSize="10" Foreground="{StaticResource BpmTextSecondary}"/>
                                </StackPanel>
                                <Border Grid.Column="2"
                                        Background="{StaticResource BpmBadgeBgWarning}"
                                        BorderBrush="{StaticResource BpmWarning}"
                                        BorderThickness="1" CornerRadius="10" Padding="8,4">
                                    <TextBlock Text="Daten gehen verloren" FontSize="10"
                                               Foreground="{StaticResource BpmWarning}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Option 3: Nur Einstellungen — GELB -->
                        <Border x:Name="BorderSettingsOnly"
                                Background="{StaticResource BpmBgElevated}"
                                BorderBrush="{StaticResource BpmBorderDefault}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,12" Margin="0,0,0,10"
                                Cursor="Hand" MouseLeftButtonDown="OnSelectReset" Tag="SettingsOnly">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="DotSettingsOnly" Grid.Column="0"
                                         Width="12" Height="12"
                                         Fill="Transparent"
                                         Stroke="{StaticResource BpmTextSecondary}" StrokeThickness="2"
                                         VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Nur Einstellungen" Style="{StaticResource BpmBodyBold}"/>
                                    <TextBlock Text="Löscht Pfade und Konfiguration. Projektdaten bleiben erhalten."
                                               Style="{StaticResource BpmSmallText}" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="settings.json"
                                               FontFamily="Consolas" FontSize="10" Foreground="{StaticResource BpmTextSecondary}"/>
                                </StackPanel>
                                <Border Grid.Column="2"
                                        Background="{StaticResource BpmBadgeBgWarning}"
                                        BorderBrush="{StaticResource BpmWarning}"
                                        BorderThickness="1" CornerRadius="10" Padding="8,4">
                                    <TextBlock Text="Pfade gehen verloren" FontSize="10"
                                               Foreground="{StaticResource BpmWarning}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Option 4: Alles — ROT -->
                        <Border x:Name="BorderAll"
                                Background="{StaticResource BpmBgElevated}"
                                BorderBrush="{StaticResource BpmBorderDefault}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,12" Margin="0,0,0,10"
                                Cursor="Hand" MouseLeftButtonDown="OnSelectReset" Tag="All">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="DotAll" Grid.Column="0"
                                         Width="12" Height="12"
                                         Fill="Transparent"
                                         Stroke="{StaticResource BpmTextSecondary}" StrokeThickness="2"
                                         VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Alles — Kompletter Neustart" Style="{StaticResource BpmBodyBold}"/>
                                    <TextBlock Text="Löscht Datenbank und alle Einstellungen. App startet wie beim allerersten Mal."
                                               Style="{StaticResource BpmSmallText}" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="bpm.db · bpm.db-wal · bpm.db-shm · settings.json"
                                               FontFamily="Consolas" FontSize="10" Foreground="{StaticResource BpmTextSecondary}"/>
                                </StackPanel>
                                <Border Grid.Column="2"
                                        Background="{StaticResource BpmBadgeBgError}"
                                        BorderBrush="{StaticResource BpmError}"
                                        BorderThickness="1" CornerRadius="10" Padding="8,4">
                                    <TextBlock Text="alles weg" FontSize="10"
                                               Foreground="{StaticResource BpmError}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Warnung -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BpmBadgeBgWarning}"
                            BorderBrush="{StaticResource BpmWarning}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="12,8" Margin="0,0,0,16">
                        <TextBlock Text="⚠  Die App wird nach dem Reset automatisch neu gestartet. Alle gewählten Daten gehen unwiderruflich verloren."
                                   Style="{StaticResource BpmSmallText}"
                                   Foreground="{StaticResource BpmWarning}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Reset Button -->
                    <Button Grid.Row="3"
                            x:Name="BtnReset"
                            Content="🗑 Ersteinrichtung zurücksetzen und neu starten"
                            Style="{StaticResource BpmButtonDanger}"
                            Click="OnReset"
                            HorizontalAlignment="Left"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Button Grid.Row="1"
                Content="Schließen"
                Style="{StaticResource BpmButtonSecondary}"
                Click="OnClose"
                HorizontalAlignment="Right"
                Margin="20,12,20,12"
                Width="100"/>
    </Grid>
</Window>
