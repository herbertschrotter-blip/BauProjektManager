<Window
    x:Class="BauProjektManager.App.DevToolsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Dev Tools [DEBUG]"
    Width="700"
    Height="600"
    MinWidth="600"
    MinHeight="500"
    Background="{StaticResource BpmBgBase}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            Style="{StaticResource BpmHeading2}"
            Text="🛠 Dev Tools" />

        <!--  Pfad-Info + Aktionen  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,16"
            Padding="16"
            Background="{StaticResource BpmBgElevated}"
            CornerRadius="4">
            <StackPanel>

                <!--  DB Pfad  -->
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource BpmLabel}"
                    Text="Datenbank" />
                <TextBlock
                    x:Name="TxtDbPath"
                    Margin="0,0,0,12"
                    Foreground="{StaticResource BpmTextSecondary}"
                    Style="{StaticResource BpmBodyText}"
                    TextWrapping="Wrap" />

                <!--  Log Verzeichnis  -->
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource BpmLabel}"
                    Text="Log-Verzeichnis" />
                <TextBlock
                    x:Name="TxtLogPath"
                    Margin="0,0,0,16"
                    Foreground="{StaticResource BpmTextSecondary}"
                    Style="{StaticResource BpmBodyText}"
                    TextWrapping="Wrap" />

                <!--  Aktions-Buttons  -->
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="BtnResetDb"
                        Margin="0,0,8,0"
                        Click="OnResetDb"
                        Content="🗑 Lokale Datenbank löschen und neu starten"
                        Style="{StaticResource BpmButtonDanger}" />
                    <Button
                        x:Name="BtnOpenLogs"
                        Click="OnOpenLogs"
                        Content="📂 Log-Ordner öffnen"
                        Style="{StaticResource BpmButtonSecondary}" />
                </StackPanel>

            </StackPanel>
        </Border>

        <!--  Log Viewer  -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource BpmLabel}"
                    Text="Log (letzte 200 Zeilen)" />
                <Button
                    Padding="8,4"
                    Click="OnRefreshLog"
                    Content="↻ Aktualisieren"
                    DockPanel.Dock="Right"
                    Style="{StaticResource BpmButtonSecondary}" />
            </DockPanel>

            <Border
                Grid.Row="1"
                Background="{StaticResource BpmBgElevated}"
                BorderBrush="{StaticResource BpmBorderDefault}"
                BorderThickness="1"
                CornerRadius="4">
                <ScrollViewer
                    x:Name="LogScroller"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <TextBlock
                        x:Name="TxtLogContent"
                        Padding="12"
                        Background="Transparent"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="{StaticResource BpmTextPrimary}"
                        TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!--  Footer  -->
        <Button
            Grid.Row="3"
            Width="100"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Click="OnClose"
            Content="Schließen"
            Style="{StaticResource BpmButtonSecondary}" />
    </Grid>
</Window>
