<Window x:Class="BauProjektManager.App.DevToolsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dev Tools [DEBUG]"
        Width="700" Height="650"
        MinWidth="600" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BpmBgBase}"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="🛠 Dev Tools"
                   Style="{StaticResource BpmHeading2}"
                   Margin="0,0,0,16"/>

        <!-- Pfad-Info + Aktionen -->
        <Border Grid.Row="1"
                Background="{StaticResource BpmBgElevated}"
                CornerRadius="4"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>

                <!-- DB Pfad -->
                <TextBlock Text="Datenbank"
                           Style="{StaticResource BpmLabel}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtDbPath"
                           Style="{StaticResource BpmBodyText}"
                           Foreground="{StaticResource BpmTextSecondary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Settings Pfad -->
                <TextBlock Text="Einstellungen"
                           Style="{StaticResource BpmLabel}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtSettingsPath"
                           Style="{StaticResource BpmBodyText}"
                           Foreground="{StaticResource BpmTextSecondary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Log Verzeichnis -->
                <TextBlock Text="Log-Verzeichnis"
                           Style="{StaticResource BpmLabel}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtLogPath"
                           Style="{StaticResource BpmBodyText}"
                           Foreground="{StaticResource BpmTextSecondary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <!-- Aktions-Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnResetDb"
                            Content="🗑 Datenbank löschen + Neustart"
                            Style="{StaticResource BpmButtonDanger}"
                            Click="OnResetDb"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnFullReset"
                            Content="⚠ Komplett-Reset + Neustart"
                            Style="{StaticResource BpmButtonDanger}"
                            Click="OnFullReset"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnOpenLogs"
                            Content="📂 Log-Ordner öffnen"
                            Style="{StaticResource BpmButtonSecondary}"
                            Click="OnOpenLogs"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Log Viewer -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Log (letzte 200 Zeilen)"
                           Style="{StaticResource BpmLabel}"
                           VerticalAlignment="Center"/>
                <Button Content="↻ Aktualisieren"
                        Style="{StaticResource BpmButtonSecondary}"
                        Click="OnRefreshLog"
                        DockPanel.Dock="Right"
                        Padding="8,4"/>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource BpmBgElevated}"
                    CornerRadius="4"
                    BorderBrush="{StaticResource BpmBorderDefault}"
                    BorderThickness="1">
                <ScrollViewer x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtLogContent"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="{StaticResource BpmTextPrimary}"
                               Background="Transparent"
                               Padding="12"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Button Grid.Row="3"
                Content="Schließen"
                Style="{StaticResource BpmButtonSecondary}"
                Click="OnClose"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Width="100"/>
    </Grid>
</Window>
