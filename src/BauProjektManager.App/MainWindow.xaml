<Window x:Class="BauProjektManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BauProjektManager"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.Row="0" Background="#2D2D30">
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="BauProjektManager"
                           FontSize="14" FontWeight="Bold"
                           Foreground="White"
                           Margin="15,5,15,15"/>
                <Button x:Name="BtnPlans" Content="📁 Pläne"
                        Click="OnNavigate" Tag="Plans"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button x:Name="BtnSettings" Content="⚙ Einstellungen"
                        Click="OnNavigate" Tag="Settings"
                        Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Grid.Row="0" Background="#1E1E1E">
            <ContentControl x:Name="ContentArea" Margin="20">
                <TextBlock Text="Willkommen im BauProjektManager"
                           FontSize="20" Foreground="#CCCCCC"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </ContentControl>
        </Border>

        <!-- Statusleiste -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="#007ACC">
            <TextBlock x:Name="StatusText"
                       Text="Bereit | Kein Projekt geladen"
                       Foreground="White"
                       VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
