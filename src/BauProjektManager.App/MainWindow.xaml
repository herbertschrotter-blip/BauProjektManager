<Window x:Class="BauProjektManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BauProjektManager"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.Row="0" Background="{StaticResource BpmBgElevated}">
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="BauProjektManager"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource BpmTextBright}"
                           Margin="15,5,15,15"/>
                <Button x:Name="BtnPlans" Content="📁 Pläne"
                        Click="OnNavigate" Tag="Plans"
                        Style="{StaticResource BpmButtonNav}"/>
                <Button x:Name="BtnSettings" Content="⚙ Einstellungen"
                        Click="OnNavigate" Tag="Settings"
                        Style="{StaticResource BpmButtonNav}"/>
                <Button x:Name="BtnDevTools" Content="🛠 Dev Tools"
                        Click="OnOpenDevTools"
                        Style="{StaticResource BpmButtonNav}"
                        Foreground="#F0AD4E"
                        Margin="0,16,0,0"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource BpmBgBase}">
            <ContentControl x:Name="ContentArea" Margin="20">
                <TextBlock Text="Willkommen im BauProjektManager"
                           Style="{StaticResource BpmHeading1}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </ContentControl>
        </Border>

        <!-- Statusleiste -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{StaticResource BpmAccentPrimary}">
            <TextBlock x:Name="StatusText"
                       Text="Bereit | Kein Projekt geladen"
                       Foreground="{StaticResource BpmTextOnAccent}"
                       Style="{StaticResource BpmSmallText}"
                       VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
