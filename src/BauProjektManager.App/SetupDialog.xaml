<Window x:Class="BauProjektManager.App.SetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BauProjektManager — Ersteinrichtung" 
        Height="480" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#2D2D30">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Willkommen im BauProjektManager!" 
                       FontSize="22" Foreground="White" FontWeight="Bold"/>
            <TextBlock Text="Ersteinrichtung — wird nur einmal benötigt." 
                       FontSize="13" Foreground="#999999" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Info -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4" Padding="12" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Foreground="#007ACC" FontWeight="Bold" Text="Erkanntes System:"/>
                <TextBlock x:Name="TxtSystemInfo" Foreground="#CCCCCC" Margin="0,5,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Pfade -->
        <StackPanel Grid.Row="2">
            <!-- OneDrive -->
            <TextBlock Text="Cloud-Speicher-Pfad:" Foreground="#CCCCCC" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtOneDrive" Grid.Column="0"
                         Background="#1E1E1E" Foreground="#CCCCCC" 
                         BorderBrush="#3E3E42" Padding="6,4" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="📁" Padding="8,4" Margin="5,0,0,0"
                        Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0"
                        Cursor="Hand" Click="OnBrowseOneDrive"/>
            </Grid>

            <!-- Arbeitsordner -->
            <TextBlock Text="Arbeitsordner (aktive Projekte):" Foreground="#CCCCCC" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtBasePath" Grid.Column="0"
                         Background="#1E1E1E" Foreground="#CCCCCC" 
                         BorderBrush="#3E3E42" Padding="6,4" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="📁" Padding="8,4" Margin="5,0,0,0"
                        Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0"
                        Cursor="Hand" Click="OnBrowseBasePath"/>
            </Grid>

            <!-- Archiv-Ordner -->
            <TextBlock Text="Archiv-Ordner (abgeschlossene Projekte, optional):" Foreground="#CCCCCC" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtArchivePath" Grid.Column="0"
                         Background="#1E1E1E" Foreground="#CCCCCC" 
                         BorderBrush="#3E3E42" Padding="6,4" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="📁" Padding="8,4" Margin="5,0,0,0"
                        Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0"
                        Cursor="Hand" Click="OnBrowseArchivePath"/>
            </Grid>

            <!-- Status -->
            <TextBlock x:Name="TxtStatus" Foreground="#FF6B6B" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Speichern und starten" x:Name="BtnSave" Click="OnSave"
                    Background="#007ACC" Foreground="White"
                    Padding="20,10" Margin="0,0,10,0"
                    BorderThickness="0" Cursor="Hand" FontSize="14"/>
            <Button Content="Abbrechen" Click="OnCancel"
                    Background="#3E3E42" Foreground="#CCCCCC"
                    Padding="20,10" BorderThickness="0" Cursor="Hand" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
