<Window x:Class="BauProjektManager.App.SetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BauProjektManager — Ersteinrichtung"
        Height="560" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{DynamicResource BpmBgElevated}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Willkommen im BauProjektManager!"
                       Style="{DynamicResource BpmHeading1}"
                       Margin="0"/>
            <TextBlock Text="Ersteinrichtung — wird nur einmal benötigt."
                       Style="{DynamicResource BpmBodyText}"
                       Foreground="{DynamicResource BpmTextSecondary}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Info -->
        <Border Grid.Row="1" Background="{DynamicResource BpmBgBase}"
                CornerRadius="4" Padding="12" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Foreground="{DynamicResource BpmAccentPrimary}"
                           FontWeight="Bold" Text="Erkanntes System:"/>
                <TextBlock x:Name="TxtSystemInfo"
                           Foreground="{DynamicResource BpmTextPrimary}"
                           Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Pfade -->
        <StackPanel Grid.Row="2">
            <!-- Cloud-Speicher -->
            <TextBlock Text="Cloud-Speicher-Pfad:"
                       Style="{DynamicResource BpmBodyText}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtOneDrive" Grid.Column="0"
                         Background="{DynamicResource BpmBgBase}"
                         Foreground="{DynamicResource BpmTextPrimary}"
                         BorderBrush="{DynamicResource BpmBorderDefault}"
                         Padding="6,4" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="{StaticResource IconActionBrowse}"
                        Margin="5,0,0,0" Click="OnBrowseOneDrive"
                        Style="{DynamicResource BpmButtonGhost}"/>
            </Grid>

            <!-- Arbeitsordner -->
            <TextBlock Text="Arbeitsordner (aktive Projekte):"
                       Style="{DynamicResource BpmBodyText}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtBasePath" Grid.Column="0"
                         Background="{DynamicResource BpmBgBase}"
                         Foreground="{DynamicResource BpmTextPrimary}"
                         BorderBrush="{DynamicResource BpmBorderDefault}"
                         Padding="6,4" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="{StaticResource IconActionBrowse}"
                        Margin="5,0,0,0" Click="OnBrowseBasePath"
                        Style="{DynamicResource BpmButtonGhost}"/>
            </Grid>

            <!-- Archiv-Ordner -->
            <TextBlock Text="Archiv-Ordner (abgeschlossene Projekte, optional):"
                       Style="{DynamicResource BpmBodyText}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtArchivePath" Grid.Column="0"
                         Background="{DynamicResource BpmBgBase}"
                         Foreground="{DynamicResource BpmTextPrimary}"
                         BorderBrush="{DynamicResource BpmBorderDefault}"
                         Padding="6,4" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="{StaticResource IconActionBrowse}"
                        Margin="5,0,0,0" Click="OnBrowseArchivePath"
                        Style="{DynamicResource BpmButtonGhost}"/>
            </Grid>

            <!-- Status -->
            <TextBlock x:Name="TxtStatus"
                       Foreground="{DynamicResource BpmError}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Speichern und starten" x:Name="BtnSave" Click="OnSave"
                    Style="{DynamicResource BpmButtonPrimary}"
                    Padding="20,10" Margin="0,0,10,0" FontSize="14"/>
            <Button Content="Abbrechen" Click="OnCancel"
                    Style="{DynamicResource BpmButtonSecondary}"
                    Padding="20,10" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
