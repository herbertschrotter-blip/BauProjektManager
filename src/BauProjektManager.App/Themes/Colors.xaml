<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         BauProjektManager — Colors.xaml (Dark Theme)
         Version: 1.0 | Datum: 30.03.2026
         Referenz: Docs/UI_UX_Guidelines.md Kapitel 3
         ═══════════════════════════════════════════════════════════ -->

    <!-- ── Hintergrund-Stufen ──────────────────────────────────── -->
    <Color x:Key="BpmColorBgBase">#1E1E1E</Color>
    <Color x:Key="BpmColorBgSurface">#252526</Color>
    <Color x:Key="BpmColorBgElevated">#2D2D30</Color>
    <Color x:Key="BpmColorBgHover">#37373D</Color>
    <Color x:Key="BpmColorBgActive">#04395E</Color>
    <Color x:Key="BpmColorBgInput">#3C3C3C</Color>

    <SolidColorBrush x:Key="BpmBgBase" Color="{StaticResource BpmColorBgBase}"/>
    <SolidColorBrush x:Key="BpmBgSurface" Color="{StaticResource BpmColorBgSurface}"/>
    <SolidColorBrush x:Key="BpmBgElevated" Color="{StaticResource BpmColorBgElevated}"/>
    <SolidColorBrush x:Key="BpmBgHover" Color="{StaticResource BpmColorBgHover}"/>
    <SolidColorBrush x:Key="BpmBgActive" Color="{StaticResource BpmColorBgActive}"/>
    <SolidColorBrush x:Key="BpmBgInput" Color="{StaticResource BpmColorBgInput}"/>

    <!-- ── Text ────────────────────────────────────────────────── -->
    <Color x:Key="BpmColorTextPrimary">#CCCCCC</Color>
    <Color x:Key="BpmColorTextSecondary">#858585</Color>
    <Color x:Key="BpmColorTextBright">#FFFFFF</Color>
    <Color x:Key="BpmColorTextOnAccent">#FFFFFF</Color>

    <SolidColorBrush x:Key="BpmTextPrimary" Color="{StaticResource BpmColorTextPrimary}"/>
    <SolidColorBrush x:Key="BpmTextSecondary" Color="{StaticResource BpmColorTextSecondary}"/>
    <SolidColorBrush x:Key="BpmTextBright" Color="{StaticResource BpmColorTextBright}"/>
    <SolidColorBrush x:Key="BpmTextOnAccent" Color="{StaticResource BpmColorTextOnAccent}"/>

    <!-- ── Akzent ──────────────────────────────────────────────── -->
    <Color x:Key="BpmColorAccentPrimary">#0078D4</Color>
    <Color x:Key="BpmColorAccentHover">#1A8AD4</Color>
    <Color x:Key="BpmColorAccentPressed">#005A9E</Color>

    <SolidColorBrush x:Key="BpmAccentPrimary" Color="{StaticResource BpmColorAccentPrimary}"/>
    <SolidColorBrush x:Key="BpmAccentHover" Color="{StaticResource BpmColorAccentHover}"/>
    <SolidColorBrush x:Key="BpmAccentPressed" Color="{StaticResource BpmColorAccentPressed}"/>

    <!-- ── Semantisch ──────────────────────────────────────────── -->
    <Color x:Key="BpmColorSuccess">#4EC94E</Color>
    <Color x:Key="BpmColorWarning">#F0AD4E</Color>
    <Color x:Key="BpmColorError">#F44747</Color>
    <Color x:Key="BpmColorInfo">#3794FF</Color>

    <SolidColorBrush x:Key="BpmSuccess" Color="{StaticResource BpmColorSuccess}"/>
    <SolidColorBrush x:Key="BpmWarning" Color="{StaticResource BpmColorWarning}"/>
    <SolidColorBrush x:Key="BpmError" Color="{StaticResource BpmColorError}"/>
    <SolidColorBrush x:Key="BpmInfo" Color="{StaticResource BpmColorInfo}"/>

    <!-- ── Ränder & Trenner ────────────────────────────────────── -->
    <Color x:Key="BpmColorBorderDefault">#3C3C3C</Color>
    <Color x:Key="BpmColorBorderFocus">#0078D4</Color>
    <Color x:Key="BpmColorBorderSubtle">#2D2D30</Color>

    <SolidColorBrush x:Key="BpmBorderDefault" Color="{StaticResource BpmColorBorderDefault}"/>
    <SolidColorBrush x:Key="BpmBorderFocus" Color="{StaticResource BpmColorBorderFocus}"/>
    <SolidColorBrush x:Key="BpmBorderSubtle" Color="{StaticResource BpmColorBorderSubtle}"/>

    <!-- ── Badge-Hintergründe (semitransparent) ───────────────── -->
    <SolidColorBrush x:Key="BpmBadgeBgSuccess" Color="#224EC94E"/>
    <SolidColorBrush x:Key="BpmBadgeBgWarning" Color="#22F0AD4E"/>
    <SolidColorBrush x:Key="BpmBadgeBgError"   Color="#22F44747"/>

    <!-- ── Transparent ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BpmTransparent" Color="Transparent"/>

</ResourceDictionary>
