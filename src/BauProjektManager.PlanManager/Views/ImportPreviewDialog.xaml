<Window x:Class="BauProjektManager.PlanManager.Views.ImportPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import-Vorschau"
        Width="1100" Height="650"
        MinWidth="800" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BpmBgBase}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Summary -->
        <Border Grid.Row="0" Background="{DynamicResource BpmBgSurface}" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Import-Vorschau" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource BpmTextBright}"/>
                <TextBlock x:Name="SummaryText" Margin="0,6,0,0"
                           FontSize="13" Foreground="{DynamicResource BpmTextSecondary}"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="DecisionGrid" Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Margin="8"
                  Background="{DynamicResource BpmBgBase}"
                  Foreground="{DynamicResource BpmTextPrimary}"
                  BorderBrush="{DynamicResource BpmBorderDefault}"
                  BorderThickness="1"
                  RowBackground="{DynamicResource BpmBgBase}"
                  AlternatingRowBackground="{DynamicResource BpmBgSurface}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="" Binding="{Binding StatusIcon}" Width="35"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Dateiname" Binding="{Binding FileName}" Width="280"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Typ" Binding="{Binding DocumentType}" Width="120"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Nr" Binding="{Binding PlanNumber}" Width="60"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Index" Binding="{Binding RevisionToken}" Width="55"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Zielordner" Binding="{Binding TargetPath}" Width="*"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BpmBgSurface}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterInfo" Grid.Column="0"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           VerticalAlignment="Center" FontSize="12"/>
                <Button Grid.Column="2" Content="Abbrechen"
                        Style="{DynamicResource BpmButtonSecondary}"
                        Margin="0,0,8,0"
                        Click="OnCancel"/>
                <Button Grid.Column="3" Content="Import ausführen"
                        Style="{DynamicResource BpmButtonPrimary}"
                        Click="OnExecute"/>
            </Grid>
        </Border>
    </Grid>
</Window>
