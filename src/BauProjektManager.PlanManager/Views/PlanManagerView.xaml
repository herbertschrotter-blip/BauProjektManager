<UserControl x:Class="BauProjektManager.PlanManager.Views.PlanManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BauProjektManager.PlanManager.ViewModels"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <!-- Projektliste (sichtbar wenn kein Projekt gewählt) -->
        <Grid x:Name="ProjectListPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Style="{DynamicResource BpmHeading1}">
                    <Run Text="{DynamicResource IconNavPlans}"/>
                    <Run Text=" PlanManager"/>
                </TextBlock>
            </Grid>

            <!-- Zusammenfassung -->
            <TextBlock Grid.Row="1"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource BpmTextSecondary}"
                       FontSize="{DynamicResource BpmFontSizeCaption}"
                       Text="{Binding SummaryText}"/>

            <!-- Suchfeld + Aktualisieren -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Suchfeld mit Platzhalter (wie Einstellungen) -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                             Background="{DynamicResource BpmBgSurface}"
                             Foreground="{DynamicResource BpmTextPrimary}"
                             BorderBrush="{DynamicResource BpmBorderDefault}"
                             Padding="8,6" FontSize="13"/>
                    <TextBlock Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="13" Padding="10,7"
                               IsHitTestVisible="False"
                               Visibility="{Binding SearchText, Converter={StaticResource EmptyToVis}}"><Run Text="{DynamicResource IconActionSearch}"/><Run Text=" Suche in Projekten..."/></TextBlock>
                </Grid>
                <Button Grid.Column="1"
                        Style="{DynamicResource BpmButtonPrimary}"
                        Command="{Binding RefreshCommand}">
                    <TextBlock>
                        <Run Text="⟳"/>
                        <Run Text=" Aktualisieren"/>
                    </TextBlock>
                </Button>
            </Grid>

            <!-- Spaltenheader -->
            <Grid Grid.Row="3" Margin="10,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Projekt"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="{DynamicResource BpmFontSizeCaption}"/>
                <TextBlock Grid.Column="1"
                           Text="Nr."
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="{DynamicResource BpmFontSizeCaption}"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="Eingang"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="{DynamicResource BpmFontSizeCaption}"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3"
                           Text="Status"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="{DynamicResource BpmFontSizeCaption}"
                           HorizontalAlignment="Center"/>
            </Grid>

            <!-- Projektliste als Karten -->
            <ListBox Grid.Row="4"
                     ItemsSource="{Binding FilteredProjects}"
                     SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                     Background="{DynamicResource BpmBgBase}"
                     BorderThickness="0"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     SelectionChanged="OnProjectSelectionChanged">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Background" Value="{DynamicResource BpmBgElevated}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BpmSuccess}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid SnapsToDevicePixels="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Farbstreifen links -->
                                        <Border x:Name="ColorStripe"
                                                Grid.Column="0"
                                                Background="{TemplateBinding BorderBrush}"
                                                CornerRadius="6,0,0,6"/>
                                        <!-- Karten-Content -->
                                        <Border x:Name="Card"
                                                Grid.Column="1"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="0,6,6,0"
                                                Padding="10,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Card"
                                                    Property="Background"
                                                    Value="{DynamicResource BpmBgHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Card"
                                                    Property="Background"
                                                    Value="{DynamicResource BpmBgHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasInbox}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource BpmWarning}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <!-- Projektname -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Project.Name}"
                                       Foreground="{DynamicResource BpmTextBright}"
                                       FontSize="{DynamicResource BpmFontSizeBody}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <!-- Projektnummer -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Project.ProjectNumber}"
                                       Foreground="{DynamicResource BpmTextSecondary}"
                                       FontSize="{DynamicResource BpmFontSizeSmall}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <!-- Eingang-Badge (unsortiert) -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource BpmWarning}"
                                    CornerRadius="8" Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasInbox, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding InboxBadge}"
                                           Foreground="{DynamicResource BpmTextBright}"
                                           FontSize="{DynamicResource BpmFontSizeCaption}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Aktuell-Badge -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource BpmSuccess}"
                                    CornerRadius="8" Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasInbox, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock Foreground="{DynamicResource BpmTextBright}"
                                           FontSize="{DynamicResource BpmFontSizeCaption}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center">
                                    <Run Text="&#x2713;"/>
                                    <Run Text=" Aktuell"/>
                                </TextBlock>
                            </Border>

                            <!-- Status -->
                            <TextBlock Grid.Column="3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource BpmSuccess}"
                                       FontSize="{DynamicResource BpmFontSizeSmall}">
                                <Run Text="●"/>
                                <Run Text=" Aktiv"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Projektzähler -->
            <TextBlock Grid.Row="5"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource BpmTextSecondary}"
                       FontSize="{DynamicResource BpmFontSizeCaption}"
                       Text="{Binding ProjectCountText}"/>

            <!-- Empty State -->
            <StackPanel Grid.Row="4"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding FilteredProjects.Count, Converter={StaticResource CountToVis}}">
                <TextBlock Text="Noch keine Projekte vorhanden."
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="{DynamicResource BpmFontSizeBody}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Erstelle zuerst ein Projekt in den Einstellungen."
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="{DynamicResource BpmFontSizeSmall}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Projektdetail (sichtbar wenn Projekt gewählt) -->
        <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
