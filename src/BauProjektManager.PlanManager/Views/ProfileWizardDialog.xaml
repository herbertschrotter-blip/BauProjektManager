<Window x:Class="BauProjektManager.PlanManager.Views.ProfileWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profil erstellen"
        Width="750" Height="550"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BpmBgElevated}"
        Foreground="{DynamicResource BpmTextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Schritt-Anzeige -->
        <Border Grid.Row="0" Background="{DynamicResource BpmBgSurface}" Padding="16,12">
            <StackPanel>
                <TextBlock FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource BpmTextBright}"
                           Text="{Binding StepTitle}"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <!-- Progress Dots -->
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BpmAccentPrimary}" Margin="0,0,6,0"/>
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BpmBorderDefault}" Margin="0,0,6,0"/>
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BpmBorderDefault}" Margin="0,0,6,0"/>
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BpmBorderDefault}"/>
                    <TextBlock Text="Schritt 1 von 4"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content: Schritt 1 — Dateiname + Segmente -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Dateiname eingeben -->
                <TextBlock Text="Beispiel-Dateiname"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="12" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SampleFileName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Background="{DynamicResource BpmBgInput}"
                             Foreground="{DynamicResource BpmTextPrimary}"
                             BorderBrush="{DynamicResource BpmBorderDefault}"
                             Padding="8,6"
                             KeyDown="OnFileNameKeyDown"/>
                    <Button Grid.Column="1" Content="Parsen"
                            Style="{DynamicResource BpmButtonSecondary}"
                            Command="{Binding ParseFileNameCommand}"
                            Margin="8,0,0,0"
                            VerticalAlignment="Stretch"/>
                </Grid>

                <!-- Trennzeichen -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Trennzeichen:"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding DelimiterText, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" Margin="8,0,0,0"
                             FontSize="13" FontFamily="Consolas"
                             Background="{DynamicResource BpmBgInput}"
                             Foreground="{DynamicResource BpmTextPrimary}"
                             BorderBrush="{DynamicResource BpmBorderDefault}"
                             Padding="6,4"/>
                    <TextBlock Text="(Leerzeichen-getrennt, z.B.: - _ .)"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Parse-Info -->
                <TextBlock Text="{Binding ParseInfo}"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="11" Margin="0,8,0,0"/>

                <!-- Segmente zuweisen -->
                <TextBlock Text="Segmente — jedem Block einen Feldtyp zuweisen:"
                           Foreground="{DynamicResource BpmTextSecondary}"
                           FontSize="12" Margin="0,20,0,8"
                           Visibility="{Binding Segments.Count, Converter={StaticResource CountToVisInverse}}"/>

                <ItemsControl ItemsSource="{Binding Segments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BpmBgSurface}"
                                    BorderBrush="{DynamicResource BpmBorderDefault}"
                                    BorderThickness="1" CornerRadius="3"
                                    Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Position -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Position}"
                                               Foreground="{DynamicResource BpmTextSecondary}"
                                               FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <!-- Wert -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RawValue}"
                                               Foreground="{DynamicResource BpmTextBright}"
                                               FontSize="14" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                    <!-- FieldType Dropdown -->
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding DataContext.FieldTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="OnFieldTypeSelectionChanged"
                                              Background="{DynamicResource BpmBgInput}"
                                              Foreground="{DynamicResource BpmTextPrimary}"
                                              BorderBrush="{DynamicResource BpmBorderDefault}"
                                              FontSize="12"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Hinweis -->
                <TextBlock Text="Pflicht: Mindestens Plannummer muss zugewiesen werden."
                           Foreground="{DynamicResource BpmWarning}"
                           FontSize="11" Margin="0,12,0,0"
                           Visibility="{Binding Segments.Count, Converter={StaticResource CountToVisInverse}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer: Abbrechen / Weiter -->
        <Border Grid.Row="2" Background="{DynamicResource BpmBgSurface}" Padding="16,10">
            <Grid>
                <Button Content="Abbrechen"
                        Style="{DynamicResource BpmButtonSecondary}"
                        HorizontalAlignment="Left"
                        Click="OnCancel"/>
                <Button Content="Weiter →"
                        Style="{DynamicResource BpmButtonPrimary}"
                        HorizontalAlignment="Right"
                        IsEnabled="{Binding CanGoNext}"
                        Click="OnNext"/>
            </Grid>
        </Border>
    </Grid>
</Window>
