<Window x:Class="BauProjektManager.PlanManager.Views.ProfileWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profil erstellen"
        Width="750" Height="580"
        MinWidth="600" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BpmBgElevated}"
        Foreground="{DynamicResource BpmTextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: 5 Progress Dots -->
        <Border Grid.Row="0" Background="{DynamicResource BpmBgSurface}" Padding="16,12">
            <StackPanel>
                <TextBlock FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource BpmTextBright}"
                           Text="{Binding StepTitle}"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{DynamicResource BpmAccentPrimary}"/>
                    <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{DynamicResource BpmBorderDefault}"/>
                    <Ellipse x:Name="Dot3" Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{DynamicResource BpmBorderDefault}"/>
                    <Ellipse x:Name="Dot4" Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{DynamicResource BpmBorderDefault}"/>
                    <Ellipse x:Name="Dot5" Width="10" Height="10"
                             Fill="{DynamicResource BpmBorderDefault}"/>
                    <TextBlock x:Name="StepCounter"
                               Text="Schritt 1 von 5"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">

            <!-- === SCHRITT 1: Datei auswaehlen + Parsen === -->
            <ScrollViewer x:Name="Step1Panel" VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <TextBlock Text="Dateien im Eingang - klicke eine Datei als Vorlage:"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" Margin="0,0,0,4"
                               Visibility="{Binding HasInboxFiles, Converter={StaticResource BoolToVis}}"/>
                    <ListBox ItemsSource="{Binding InboxFiles}"
                             SelectedItem="{Binding SelectedInboxFile}"
                             MaxHeight="140"
                             Background="{DynamicResource BpmBgSurface}"
                             Foreground="{DynamicResource BpmTextPrimary}"
                             BorderBrush="{DynamicResource BpmBorderDefault}"
                             BorderThickness="1"
                             FontSize="12" FontFamily="Consolas"
                             Margin="0,0,0,12"
                             Visibility="{Binding HasInboxFiles, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Text="Beispiel-Dateiname"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SampleFileName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13"
                                 Background="{DynamicResource BpmBgInput}"
                                 Foreground="{DynamicResource BpmTextPrimary}"
                                 BorderBrush="{DynamicResource BpmBorderDefault}"
                                 Padding="8,6" KeyDown="OnFileNameKeyDown"/>
                        <Button Grid.Column="1" Content="Parsen"
                                Style="{DynamicResource BpmButtonSecondary}"
                                Command="{Binding ParseFileNameCommand}"
                                Margin="8,0,0,0" VerticalAlignment="Stretch"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Trennzeichen:"
                                   Foreground="{DynamicResource BpmTextSecondary}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding DelimiterText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" Margin="8,0,0,0"
                                 FontSize="13" FontFamily="Consolas"
                                 Background="{DynamicResource BpmBgInput}"
                                 Foreground="{DynamicResource BpmTextPrimary}"
                                 BorderBrush="{DynamicResource BpmBorderDefault}"
                                 Padding="6,4"/>
                        <TextBlock Text="(Leerzeichen-getrennt, z.B.: - _ .)"
                                   Foreground="{DynamicResource BpmTextSecondary}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ParseInfo}"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" Margin="0,8,0,0"/>

                    <!-- Segment-Vorschau (nur Anzeige, keine Dropdowns) -->
                    <TextBlock Text="Erkannte Segmente:"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" Margin="0,16,0,8"
                               Visibility="{Binding Segments.Count, Converter={StaticResource CountToVisInverse}}"/>
                    <ItemsControl ItemsSource="{Binding Segments}"
                                  Visibility="{Binding Segments.Count, Converter={StaticResource CountToVisInverse}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BpmBgSurface}"
                                        BorderBrush="{DynamicResource BpmBorderDefault}"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="10,6" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding RawValue}"
                                               Foreground="{DynamicResource BpmTextBright}"
                                               FontSize="13" FontFamily="Consolas"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- === SCHRITT 2: Segmente zuweisen === -->
            <ScrollViewer x:Name="Step2Panel" VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Jedem Segment einen Feldtyp zuweisen:"
                               Foreground="{DynamicResource BpmTextBright}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding Segments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BpmBgSurface}"
                                        BorderBrush="{DynamicResource BpmBorderDefault}"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Position}"
                                                   Foreground="{DynamicResource BpmTextSecondary}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RawValue}"
                                                   Foreground="{DynamicResource BpmTextBright}"
                                                   FontSize="14" FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding DataContext.FieldTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectionChanged="OnFieldTypeSelectionChanged"
                                                  Background="{DynamicResource BpmBgInput}"
                                                  Foreground="{DynamicResource BpmTextPrimary}"
                                                  BorderBrush="{DynamicResource BpmBorderDefault}"
                                                  FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Pflicht: Mindestens Plannummer muss zugewiesen werden."
                               Foreground="{DynamicResource BpmWarning}"
                               FontSize="11" Margin="0,12,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- === SCHRITT 3: IndexSource === -->
            <ScrollViewer x:Name="Step3Panel" VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Wie wird der Index (Revision) erkannt?"
                               Foreground="{DynamicResource BpmTextBright}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding IndexSourceOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,0,0,12">
                                    <StackPanel>
                                        <RadioButton GroupName="IndexSource"
                                                     IsEnabled="{Binding IsEnabled}"
                                                     Checked="OnIndexSourceChecked"
                                                     Foreground="{DynamicResource BpmTextPrimary}"
                                                     FontSize="13">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                        </RadioButton>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource BpmTextSecondary}"
                                                   FontSize="11" Margin="20,2,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,8,0,0" Padding="12"
                            Background="{DynamicResource BpmBgSurface}"
                            BorderBrush="{DynamicResource BpmBorderDefault}"
                            BorderThickness="1" CornerRadius="4"
                            Visibility="{Binding ShowIndexModeOptions, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Index-Modus"
                                       Foreground="{DynamicResource BpmTextBright}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <RadioButton GroupName="IndexMode"
                                         IsChecked="{Binding IndexModeOptional}"
                                         Foreground="{DynamicResource BpmTextPrimary}"
                                         FontSize="12" Margin="0,0,0,6">
                                <TextBlock Text="Optional (Erstausgabe kann ohne Index sein)"/>
                            </RadioButton>
                            <RadioButton GroupName="IndexMode"
                                         Foreground="{DynamicResource BpmTextPrimary}"
                                         FontSize="12">
                                <TextBlock Text="Pflicht (Jedes Dokument muss einen Index haben)"/>
                            </RadioButton>
                            <Separator Margin="0,12,0,12"
                                       Background="{DynamicResource BpmBorderDefault}"/>
                            <CheckBox IsChecked="{Binding IndexCaseInsensitive}"
                                      Foreground="{DynamicResource BpmTextPrimary}"
                                      FontSize="12">
                                <TextBlock Text="Gross-/Kleinschreibung ignorieren (A = a)"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Padding="10"
                            Background="{DynamicResource BpmBgSurface}"
                            BorderBrush="{DynamicResource BpmWarning}"
                            BorderThickness="1" CornerRadius="4"
                            Visibility="{Binding ShowIndexWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Foreground="{DynamicResource BpmWarning}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Text="In Schritt 2 wurde kein Index-Segment zugewiesen. Gehe zurueck und weise einem Segment den Typ 'Index' zu, oder waehle 'Kein Index'."/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- === SCHRITT 4: Zielordner === -->
            <ScrollViewer x:Name="Step4Panel" VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Wohin sollen die Dokumente sortiert werden?"
                               Foreground="{DynamicResource BpmTextBright}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Hauptordner"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding TargetFolderOptions}"
                              SelectedItem="{Binding SelectedTargetFolder}"
                              Background="{DynamicResource BpmBgInput}"
                              Foreground="{DynamicResource BpmTextPrimary}"
                              BorderBrush="{DynamicResource BpmBorderDefault}"
                              FontSize="13" Margin="0,0,0,8"/>

                    <CheckBox IsChecked="{Binding UseCustomFolder}"
                              Foreground="{DynamicResource BpmTextPrimary}"
                              FontSize="12" Margin="0,0,0,4">
                        <TextBlock Text="Eigenen Ordnernamen eingeben"/>
                    </CheckBox>
                    <TextBox Text="{Binding CustomFolderName, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding UseCustomFolder, Converter={StaticResource BoolToVis}}"
                             FontSize="13"
                             Background="{DynamicResource BpmBgInput}"
                             Foreground="{DynamicResource BpmTextPrimary}"
                             BorderBrush="{DynamicResource BpmBorderDefault}"
                             Padding="8,6" Margin="0,0,0,12"/>

                    <TextBlock Text="Unterordner-Ebenen (optional)"
                               Foreground="{DynamicResource BpmTextBright}"
                               FontSize="13" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <TextBlock Text="Dokumente werden in Unterordner sortiert nach:"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding AvailableHierarchyLevels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}"
                                          Checked="OnHierarchyCheckChanged"
                                          Unchecked="OnHierarchyCheckChanged"
                                          Foreground="{DynamicResource BpmTextPrimary}"
                                          FontSize="12" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                        <TextBlock Text=" (z.B. "
                                                   Foreground="{DynamicResource BpmTextSecondary}"/>
                                        <TextBlock Text="{Binding SampleValue}"
                                                   Foreground="{DynamicResource BpmAccentPrimary}"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Text=")"
                                                   Foreground="{DynamicResource BpmTextSecondary}"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Keine Segmente mit Ordner-Ebenen in Schritt 2 zugewiesen."
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" FontStyle="Italic" Margin="0,4,0,0"
                               Visibility="{Binding AvailableHierarchyLevels.Count, Converter={StaticResource CountToVisZero}}"/>

                    <Border Margin="0,16,0,0" Padding="12"
                            Background="{DynamicResource BpmBgSurface}"
                            BorderBrush="{DynamicResource BpmBorderDefault}"
                            BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Vorschau Zielpfad"
                                       Foreground="{DynamicResource BpmTextSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding FolderPreview}"
                                       Foreground="{DynamicResource BpmAccentPrimary}"
                                       FontSize="14" FontFamily="Consolas"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- === SCHRITT 5: Erkennung (klickbare Segmente) === -->
            <ScrollViewer x:Name="Step5Panel" VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="Collapsed">
                <StackPanel>
                    <!-- Dokumenttyp-Name -->
                    <TextBlock Text="Dokumenttyp-Name"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DocumentTypeName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Background="{DynamicResource BpmBgInput}"
                             Foreground="{DynamicResource BpmTextPrimary}"
                             BorderBrush="{DynamicResource BpmBorderDefault}"
                             Padding="8,6" Margin="0,0,0,16"/>

                    <!-- Klickbare Segmente -->
                    <TextBlock Text="Welche Teile identifizieren diesen Dokumenttyp?"
                               Foreground="{DynamicResource BpmTextBright}"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Klicke auf die Teile die bei diesem Typ immer gleich sind:"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding RecognitionSegments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="OnRecognitionSegmentClick"
                                        Margin="0,0,6,6" Padding="10,6"
                                        FontSize="13" FontFamily="Consolas"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource BpmBgSurface}"/>
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource BpmTextSecondary}"/>
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource BpmBorderDefault}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background"
                                                            Value="{DynamicResource BpmAccentPrimary}"/>
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource BpmTextBright}"/>
                                                    <Setter Property="BorderBrush"
                                                            Value="{DynamicResource BpmAccentPrimary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding RawValue}"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Erkennungsmuster + Test -->
                    <Border Margin="0,12,0,0" Padding="12"
                            Background="{DynamicResource BpmBgSurface}"
                            BorderBrush="{DynamicResource BpmBorderDefault}"
                            BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Erkennungsmuster: "
                                           Foreground="{DynamicResource BpmTextSecondary}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding RecognitionPattern}"
                                           Foreground="{DynamicResource BpmAccentPrimary}"
                                           FontSize="12" FontFamily="Consolas"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Methode: "
                                           Foreground="{DynamicResource BpmTextSecondary}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedRecognitionMethod}"
                                           Foreground="{DynamicResource BpmTextPrimary}"
                                           FontSize="11"/>
                                <TextBlock Text=" (automatisch erkannt)"
                                           Foreground="{DynamicResource BpmTextSecondary}"
                                           FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Test: "
                                           Foreground="{DynamicResource BpmTextSecondary}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SampleFileName, Mode=OneWay}"
                                           Foreground="{DynamicResource BpmTextPrimary}"
                                           FontSize="11" FontFamily="Consolas"/>
                            </StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       Text="{Binding PatternTestResult}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource BpmError}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PatternTestSuccess}"
                                                         Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource BpmSuccess}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Prioritaet -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Prioritaet (hoeher = wird zuerst geprueft)"
                                   Foreground="{DynamicResource BpmTextSecondary}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding RecognitionPriority, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" Margin="12,0,0,0"
                                 FontSize="13" FontFamily="Consolas"
                                 Background="{DynamicResource BpmBgInput}"
                                 Foreground="{DynamicResource BpmTextPrimary}"
                                 BorderBrush="{DynamicResource BpmBorderDefault}"
                                 Padding="6,4"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BpmBgSurface}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Abbrechen"
                        Style="{DynamicResource BpmButtonSecondary}"
                        Click="OnCancel"/>
                <Button Grid.Column="1" Content="Zurueck"
                        Style="{DynamicResource BpmButtonSecondary}"
                        HorizontalAlignment="Right" Margin="0,0,8,0"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}"
                        Click="OnBack"/>
                <Button x:Name="NextButton" Grid.Column="2" Content="Weiter"
                        Style="{DynamicResource BpmButtonPrimary}"
                        IsEnabled="{Binding CanGoNext}"
                        Click="OnNext"/>
            </Grid>
        </Border>
    </Grid>
</Window>
