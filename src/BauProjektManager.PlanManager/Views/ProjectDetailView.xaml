<UserControl x:Class="BauProjektManager.PlanManager.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: ← Zurück + Projektname + Import starten -->
        <Border Grid.Row="0" Background="{DynamicResource BpmBgSurface}"
                Padding="8,6" Margin="0,0,0,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="← Zurück"
                            Style="{DynamicResource BpmButtonGhost}"
                            Command="{Binding GoBackCommand}"
                            Foreground="{DynamicResource BpmTextSecondary}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Project.Name}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource BpmTextBright}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>
                <Button Content="Import starten"
                        Style="{DynamicResource BpmButtonPrimary}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="OnStartImport"/>
            </Grid>
        </Border>

        <!-- Eingang-Banner (nur wenn Dateien im Eingang) -->
        <Border Grid.Row="1"
                Background="{DynamicResource BpmWarning}"
                Padding="10,6" Margin="0,0,0,8"
                CornerRadius="3"
                Visibility="{Binding HasInbox, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding InboxInfo}"
                       Foreground="{DynamicResource BpmTextBright}"
                       FontSize="12" FontWeight="SemiBold"/>
        </Border>

        <!-- 3 Tabs -->
        <TabControl Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource BpmTextPrimary}">

            <!-- Tab 1: Profile -->
            <TabItem Header="Profile">
                <Grid Margin="0,12,0,0">
                    <Button Content="+ Neuer Dokumenttyp"
                            Style="{DynamicResource BpmButtonSecondary}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Click="OnNewProfile"/>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Noch keine Profile angelegt."
                                   Foreground="{DynamicResource BpmTextSecondary}"
                                   FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="Klicke + Neuer Dokumenttyp um einen Dateinamen anzulernen."
                                   Foreground="{DynamicResource BpmTextSecondary}"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Manuell sortieren -->
            <TabItem Header="Manuell sortieren">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Manueller Sortier-Modus"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="Für Scans und nicht erkannte Dateien. (kommt mit #32)"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 3: Sync -->
            <TabItem Header="Sync">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Ordner-Sync"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="Firmenserver ↔ OneDrive Sync. (Post-V1, BACKLOG #35)"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="11" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
