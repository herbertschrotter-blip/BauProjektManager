<Window x:Class="BauProjektManager.Settings.Views.ProjectEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projekt bearbeiten"
        Height="680" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2D2D30">
    <Window.Resources>
        <!-- Dark DatePicker Style -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <TextBox x:Name="PART_TextBox"
                                 Text="{Binding Path=SelectedDate, RelativeSource={RelativeSource AncestorType=DatePicker}, StringFormat=dd.MM.yyyy}"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderThickness="0" Padding="2"
                                 IsReadOnly="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="#1E1E1E" BorderBrush="#3E3E42"
                                          BorderThickness="1" Padding="5,3"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" Padding="5,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#CCCCCC"
                                                      StrokeThickness="1.5" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,3,25,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="#1E1E1E" BorderBrush="#3E3E42"
                                        BorderThickness="1" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Projekt bearbeiten"
                   FontSize="18" Foreground="#CCCCCC" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Stammdaten -->
                <TextBlock Text="── Stammdaten ──" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Projektstart:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                        <DatePicker x:Name="DpProjectStart" Width="150"
                                    SelectedDateChanged="OnProjectStartChanged"/>
                        <TextBlock Text="  →  Nr:" Foreground="#999999" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtNumberPreview" Text="" Foreground="#007ACC"
                                   FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Projektname:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtName"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Voller Name:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtFullName"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="CmbStatus" Margin="0,4"/>
                </Grid>

                <!-- Auftraggeber -->
                <TextBlock Text="── Auftraggeber ──" Foreground="#007ACC" FontWeight="Bold" Margin="0,15,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Firma:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtClientCompany"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Kontaktperson:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtClientContact"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Telefon:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtClientPhone"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtClientEmail"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>
                </Grid>

                <!-- Adresse -->
                <TextBlock Text="── Adresse ──" Foreground="#007ACC" FontWeight="Bold" Margin="0,15,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Straße / Nr:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtStreet"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>
                    <TextBox Grid.Row="0" Grid.Column="2" x:Name="TxtHouseNumber"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="5,4,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="PLZ / Ort:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtPostalCode"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>
                        <TextBox Grid.Column="1" x:Name="TxtCity"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3E3E42" Padding="5,3" Margin="5,4,0,4"/>
                    </Grid>
                </Grid>

                <!-- Verwaltung -->
                <TextBlock Text="── Verwaltung ──" Foreground="#007ACC" FontWeight="Bold" Margin="0,15,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Gemeinde:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtMunicipality"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bezirk:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtDistrict"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Bundesland:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtState"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>
                </Grid>

                <!-- Sonstiges -->
                <TextBlock Text="── Sonstiges ──" Foreground="#007ACC" FontWeight="Bold" Margin="0,15,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tags:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTags"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Notizen:"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNotes"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"
                             Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Speichern" x:Name="BtnSave" Click="OnSave"
                    Background="#007ACC" Foreground="White"
                    Padding="20,8" Margin="0,0,10,0"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="Abbrechen" x:Name="BtnCancel" Click="OnCancel"
                    Background="#3E3E42" Foreground="#CCCCCC"
                    Padding="20,8" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
