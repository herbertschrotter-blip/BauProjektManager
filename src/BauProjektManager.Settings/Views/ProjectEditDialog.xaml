<Window x:Class="BauProjektManager.Settings.Views.ProjectEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BauProjektManager.Settings.Views"
        Title="Projekt bearbeiten"
        Height="900" Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BpmBgElevated}">
    <Window.Resources>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BpmBorderDefault}"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <TextBox x:Name="PART_TextBox"
                                 Text="{Binding Path=SelectedDate, RelativeSource={RelativeSource AncestorType=DatePicker}, StringFormat=dd.MM.yyyy}"
                                 Background="{DynamicResource BpmBgBase}" Foreground="{DynamicResource BpmTextPrimary}"
                                 BorderThickness="0" Padding="2" IsReadOnly="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BpmBorderDefault}"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{DynamicResource BpmBgBase}"
                                          BorderBrush="{DynamicResource BpmBorderDefault}"
                                          BorderThickness="1" Padding="5,3"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{DynamicResource BpmBgBase}"
                                                BorderBrush="{DynamicResource BpmBorderDefault}"
                                                BorderThickness="1" Padding="5,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                      Stroke="{DynamicResource BpmTextPrimary}"
                                                      StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,3,25,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="{DynamicResource BpmBgBase}"
                                        BorderBrush="{DynamicResource BpmBorderDefault}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BpmAccentPrimary}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BpmAccentPressed}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabControl" x:Key="DialogTabs">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem" x:Key="DialogTabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource BpmAccentPrimary}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FTB" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BpmBorderDefault}"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style x:Key="SH" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BpmAccentPrimary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource BpmBgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkDgCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BpmBgActive}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- DataGrid Header Styles -->
        <Style x:Key="DgHeaderPrimary" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BpmBgSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BpmBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="DgHeaderSecondary" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BpmBgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BpmBorderDefault}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
        <!-- DataGrid Base Style -->
        <Style x:Key="DgBase" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BpmBorderDefault}"/>
            <Setter Property="RowBackground" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource BpmBgBase}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BpmBorderDefault}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtDialogTitle" Text="Projekt bearbeiten"
                   Style="{DynamicResource BpmHeading2}" Margin="0,0,0,10"/>

        <TabControl Grid.Row="1" Style="{StaticResource DialogTabs}">

            <!-- ═══ TAB 1: STAMMDATEN ═══ -->
            <TabItem Header="Stammdaten" Style="{StaticResource DialogTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="Projekt" Style="{StaticResource SH}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Projektstart:" Style="{StaticResource FL}"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                    <DatePicker x:Name="DpProjectStart" Width="140" SelectedDateChanged="OnProjectStartChanged"/>
                                    <TextBlock Text="  →  Nr:" Foreground="{DynamicResource BpmTextSecondary}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtNumberPreview" Text=""
                                               Foreground="{DynamicResource BpmAccentPrimary}"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Projektname:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtName" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Voller Name:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtFullName" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Projektart:" Style="{StaticResource FL}"/>
                                <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,3">
                                    <Button DockPanel.Dock="Right" Content="{StaticResource IconActionEdit}" Style="{StaticResource IconBtn}" Click="OnEditProjectTypes" ToolTip="Liste bearbeiten" Margin="4,0,0,0"/>
                                    <ComboBox x:Name="CmbProjectType"/>
                                </DockPanel>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Status:" Style="{StaticResource FL}"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbStatus" Margin="0,3"/>
                            </Grid>
                            <TextBlock Text="Auftraggeber" Style="{StaticResource SH}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Firma:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtClientCompany" Style="{StaticResource FTB}"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="{StaticResource IconActionCopy}" Style="{StaticResource IconBtn}" IsEnabled="False" Opacity="0.4" Margin="4,3,0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Kontakt:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtClientContact" Style="{StaticResource FTB}"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="{StaticResource IconPerson}" Style="{StaticResource IconBtn}" IsEnabled="False" Opacity="0.4" Margin="4,3,0,3"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Telefon:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtClientPhone" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtClientEmail" Style="{StaticResource FTB}"/>
                            </Grid>
                            <TextBlock Text="Sonstiges" Style="{StaticResource SH}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tags:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTags" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Notizen:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNotes" Style="{StaticResource FTB}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </StackPanel>
                        <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BpmBorderDefault}" Margin="9,0"/>
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock Text="Adresse" Style="{StaticResource SH}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Straße / Nr:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtStreet" Style="{StaticResource FTB}"/>
                                <TextBox Grid.Row="0" Grid.Column="2" x:Name="TxtHouseNumber" Style="{StaticResource FTB}" Margin="5,3,0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="PLZ / Ort:" Style="{StaticResource FL}"/>
                                <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="TxtPostalCode" Style="{StaticResource FTB}"/>
                                    <TextBox Grid.Column="1" x:Name="TxtCity" Style="{StaticResource FTB}" Margin="5,3,0,3"/>
                                </Grid>
                            </Grid>
                            <DockPanel Margin="0,12,0,6">
                                <TextBlock Text="Verwaltung" Foreground="{DynamicResource BpmAccentPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="GIS" Style="{StaticResource IconBtn}" FontSize="10" IsEnabled="False" Opacity="0.4"
                                        MinWidth="50" Padding="12,4" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gemeinde:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtMunicipality" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Bezirk:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtDistrict" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bundesland:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtState" Style="{StaticResource FTB}"/>
                            </Grid>
                            <DockPanel Margin="0,12,0,6">
                                <TextBlock Text="Grundstück + Koordinaten" Foreground="{DynamicResource BpmAccentPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="GIS" Style="{StaticResource IconBtn}" FontSize="10" IsEnabled="False" Opacity="0.4"
                                        MinWidth="50" Padding="12,4" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="KG / Name:" Style="{StaticResource FL}"/>
                                <Grid Grid.Row="0" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="TxtCadastralKg" Style="{StaticResource FTB}"/>
                                    <TextBox Grid.Column="1" x:Name="TxtCadastralKgName" Style="{StaticResource FTB}" Margin="5,3,0,3"/>
                                </Grid>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="GST-Nr:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCadastralGst" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Koord.System:" Style="{StaticResource FL}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtCoordSystem" Style="{StaticResource FTB}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ost / Nord:" Style="{StaticResource FL}"/>
                                <Grid Grid.Row="3" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="TxtCoordEast" Style="{StaticResource FTB}"/>
                                    <TextBox Grid.Column="1" x:Name="TxtCoordNorth" Style="{StaticResource FTB}" Margin="5,3,0,3"/>
                                </Grid>
                            </Grid>
                            <TextBlock Text="Laufzeit" Style="{StaticResource SH}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Baustart:" Style="{StaticResource FL}"/>
                                <DatePicker Grid.Row="0" Grid.Column="1" x:Name="DpConstructionStart" Margin="0,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Gepl. Ende:" Style="{StaticResource FL}" Margin="10,3,0,3"/>
                                <DatePicker Grid.Row="0" Grid.Column="3" x:Name="DpPlannedEnd" Margin="0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tats. Ende:" Style="{StaticResource FL}"/>
                                <DatePicker Grid.Row="1" Grid.Column="1" x:Name="DpActualEnd" Margin="0,3"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB 2: BAUWERK ═══ -->
            <TabItem Header="Bauwerk" Style="{StaticResource DialogTabItem}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="180"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ── Bauteile (obere Hälfte) ── -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Bauteile" Style="{StaticResource SH}" Margin="0,0,0,4"/>

                        <!-- Globales ± 0,00 Toggle -->
                        <Border Grid.Row="1" Background="{DynamicResource BpmBgSurface}"
                                BorderBrush="{DynamicResource BpmBorderDefault}" BorderThickness="0.5"
                                CornerRadius="4" Padding="8,5" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <!-- Ovaler Toggle-Switch -->
                                <Border x:Name="ToggleTrack" Width="38" Height="20" CornerRadius="10"
                                        Background="#555" Cursor="Hand" VerticalAlignment="Center"
                                        MouseLeftButtonDown="OnToggleGlobalZero">
                                    <Ellipse x:Name="ToggleKnob" Width="16" Height="16"
                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                </Border>
                                <TextBlock Text="Globales ± 0,00 Niveau"
                                           Foreground="{DynamicResource BpmTextPrimary}" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <TextBox x:Name="TxtGlobalZero" Width="80" Margin="12,0,8,0"
                                         Background="{DynamicResource BpmBgBase}"
                                         Foreground="#EF9F27"
                                         BorderBrush="{DynamicResource BpmBorderDefault}"
                                         TextAlignment="Right" FontSize="12"
                                         Visibility="Collapsed"
                                         TextChanged="OnGlobalZeroValueChanged"/>
                                <TextBlock x:Name="TxtGlobalZeroHint" Text="m ü.A. — wird auf alle Bauteile übernommen"
                                           Foreground="{DynamicResource BpmTextSecondary}" FontSize="11"
                                           VerticalAlignment="Center" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="2" Text="Jedes Bauteil hat eigene Geschosse."
                                   Style="{DynamicResource BpmSmallText}" Margin="0,0,0,6"/>
                        <DataGrid Grid.Row="3" x:Name="DgParts" Style="{StaticResource DgBase}"
                                  ColumnHeaderStyle="{StaticResource DgHeaderPrimary}"
                                  CellStyle="{StaticResource DarkDgCell}"
                                  SelectionChanged="OnPartSelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kürzel" Binding="{Binding ShortName}" Width="80"/>
                                <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Bauwerkstyp" Binding="{Binding BuildingType}" Width="120"/>
                                <DataGridTextColumn Header="± 0,00 abs." Binding="{Binding ZeroLevelAbsolute, StringFormat=F2}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ Bauteil" Click="OnAddPart" Style="{DynamicResource BpmButtonPrimary}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                            <Button Content="Bearbeiten" Click="OnEditPart" Style="{DynamicResource BpmButtonSecondary}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                            <Button Content="Entfernen" Click="OnRemovePart" Style="{DynamicResource BpmButtonDanger}" Padding="10,5" MinWidth="0" MinHeight="0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── GridSplitter ── -->
                    <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BpmBorderDefault}" Cursor="SizeNS"
                                  ShowsPreview="True" Margin="0,4"/>

                    <!-- ── Geschosse (untere Hälfte) ── -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                            <TextBlock x:Name="TxtLevelsHeader" Text="Geschosse" Style="{StaticResource SH}" Margin="0" VerticalAlignment="Center"/>
                            <Button Content="{StaticResource IconActionEdit}" Style="{StaticResource IconBtn}" Click="OnEditLevelNames" ToolTip="Geschoss-Liste bearbeiten" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Foreground="{DynamicResource BpmTextSecondary}" FontSize="11" Text="Direkt editierbar · Komma als Dezimalzeichen · Prefix + Beschreibung automatisch · "/>
                            <TextBlock x:Name="TxtZeroInfo" Foreground="#5DCAA5" FontSize="11"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="DgLevels" Style="{StaticResource DgBase}"
                                  IsReadOnly="False" CanUserAddRows="False"
                                  ColumnHeaderStyle="{StaticResource DgHeaderSecondary}"
                                  CellStyle="{StaticResource DarkDgCell}"
                                  CellEditEnding="OnLevelCellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Prefix" Binding="{Binding PrefixString}" Width="55" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridComboBoxColumn Header="GS" Width="70" x:Name="ColLevelName"
                                                        SelectedItemBinding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Beschreib." Binding="{Binding Description}" Width="90" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="RDOK" Binding="{Binding Rdok, StringFormat=F2}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#EF9F27"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource BpmBgSurface}"/>
                                            <Setter Property="Foreground" Value="#EF9F27"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="FBOK" Binding="{Binding Fbok, StringFormat=F2}" Width="70">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource BpmBgSurface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="RDUK" Binding="{Binding RdukDisplay}" Width="70">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource BpmBgSurface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Gesch.h." Binding="{Binding StoryHeight, StringFormat=F2}" Width="70" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Rohb.h." Binding="{Binding RawHeight, StringFormat=F2}" Width="70" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Deck.st." Binding="{Binding DeckThickness, StringFormat=F2}" Width="65" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="FB-Aufb." Binding="{Binding FloorBuildup, StringFormat=F2}" Width="65" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ Geschoss" Click="OnAddLevel" Style="{DynamicResource BpmButtonPrimary}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                            <Button Content="Bearbeiten" Click="OnEditLevel" Style="{DynamicResource BpmButtonSecondary}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                            <Button Content="Entfernen" Click="OnRemoveLevel" Style="{DynamicResource BpmButtonDanger}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                            <Button Content="{StaticResource IconArrowUp}" Click="OnMoveLevelUp" Style="{DynamicResource BpmButtonSecondary}" Padding="8,5" Margin="0,0,3,0" MinWidth="0" MinHeight="0"/>
                            <Button Content="{StaticResource IconArrowDown}" Click="OnMoveLevelDown" Style="{DynamicResource BpmButtonSecondary}" Padding="8,5" MinWidth="0" MinHeight="0"/>
                        </StackPanel>

                        </Grid>

                    <!-- ── Info-Legende (fixiert unten) ── -->
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Eingabe (3 Werte)" Foreground="{DynamicResource BpmAccentPrimary}" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" Text="RDOK: Rohdecken-OK (unterstes = Bodenplatten-OK)"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" Text="FBOK: Fertigfußboden-OK"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" Text="RDUK: Rohdecken-UK (unterstes: leer lassen)"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Live errechnet" Foreground="{DynamicResource BpmAccentPrimary}" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" FontStyle="Italic" Text="Gesch.h. = FBOK(n+1) − FBOK(n)"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" FontStyle="Italic" Text="Rohb.h. = RDOK(n+1) − RDOK(n)"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" FontStyle="Italic" Text="Deck.st. = RDOK(n+1) − RDUK(n)"/>
                            <TextBlock Style="{DynamicResource BpmSmallText}" FontStyle="Italic" Text="FB-Aufb. = FBOK − RDOK"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 3: BETEILIGTE ═══ -->
            <TabItem Header="Beteiligte" Style="{StaticResource DialogTabItem}">
                <StackPanel Margin="0,10,0,0">
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Beteiligte Firmen / Personen" Style="{StaticResource SH}" Margin="0"/>
                        <Button Content="{StaticResource IconActionEdit}" Style="{StaticResource IconBtn}" Click="OnEditParticipantRoles" ToolTip="Rollen-Liste bearbeiten" Margin="8,12,0,6"/>
                    </DockPanel>
                    <DataGrid x:Name="DgParticipants" Style="{StaticResource DgBase}" Height="380"
                              ColumnHeaderStyle="{StaticResource DgHeaderPrimary}"
                              CellStyle="{StaticResource DarkDgCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rolle" Binding="{Binding Role}" Width="120"/>
                            <DataGridTextColumn Header="Firma" Binding="{Binding Company}" Width="*"/>
                            <DataGridTextColumn Header="Kontaktperson" Binding="{Binding ContactPerson}" Width="140"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                        <Button Content="+ Beteiligten" Click="OnAddParticipant" Style="{DynamicResource BpmButtonPrimary}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                        <Button Content="Bearbeiten" Click="OnEditParticipant" Style="{DynamicResource BpmButtonSecondary}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                        <Button Content="Entfernen" Click="OnRemoveParticipant" Style="{DynamicResource BpmButtonDanger}" Padding="10,5" Margin="0,0,6,0" MinWidth="0" MinHeight="0"/>
                        <Button Content="{StaticResource IconArrowUp}" Click="OnMoveParticipantUp" Style="{DynamicResource BpmButtonSecondary}" Padding="8,5" Margin="0,0,3,0" MinWidth="0" MinHeight="0"/>
                        <Button Content="{StaticResource IconArrowDown}" Click="OnMoveParticipantDown" Style="{DynamicResource BpmButtonSecondary}" Padding="8,5" MinWidth="0" MinHeight="0"/>
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource BpmBorderDefault}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Import" Foreground="{DynamicResource BpmAccentPrimary}" FontWeight="Bold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Liste importieren" IsEnabled="False" Opacity="0.5"
                                        Background="#085041" Foreground="#5DCAA5" Padding="10,5" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0"
                                        ToolTip="Firmenliste per KI-Prompt importieren (kommt später)"/>
                                <Button Content="Aus Adressbuch" IsEnabled="False" Opacity="0.5"
                                        Style="{DynamicResource BpmButtonSecondary}" Padding="10,5"
                                        ToolTip="Aus zentralem Adressbuch übernehmen (kommt später)"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ═══ TAB 4: PORTALE + LINKS ═══ -->
            <TabItem Header="Portale + Links" Style="{StaticResource DialogTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Linke Spalte: Bauherren-Portale -->
                            <StackPanel Grid.Column="0">
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Bauherren-Portale" Style="{StaticResource SH}" Margin="0"/>
                                    <Button Content="{StaticResource IconActionEdit}" Style="{StaticResource IconBtn}" Click="OnEditPortalTypes" ToolTip="Portal-Typen bearbeiten" Margin="8,12,0,6"/>
                                </DockPanel>
                                <TextBlock Text="Externe Plattformen des Auftraggebers. Portal-Typen konfigurierbar."
                                           Style="{DynamicResource BpmSmallText}" Margin="0,0,0,8"/>
                                <DataGrid x:Name="DgPortals" Style="{StaticResource DgBase}" Height="260"
                                          ColumnHeaderStyle="{StaticResource DgHeaderPrimary}"
                                          CellStyle="{StaticResource DarkDgCell}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Portal" Binding="{Binding Name}" Width="100"/>
                                        <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource BpmInfo}"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="+ Portal" Click="OnAddPortal" Style="{DynamicResource BpmButtonPrimary}" Padding="8,4" Margin="0,0,4,0" FontSize="11" MinWidth="0" MinHeight="0"/>
                                    <Button Content="Bearbeiten" Click="OnEditPortal" Style="{DynamicResource BpmButtonSecondary}" Padding="8,4" Margin="0,0,4,0" FontSize="11" MinWidth="0" MinHeight="0"/>
                                    <Button Content="Entfernen" Click="OnRemovePortal" Style="{DynamicResource BpmButtonDanger}" Padding="8,4" Margin="0,0,4,0" FontSize="11" MinWidth="0" MinHeight="0"/>
                                    <Button Content="Öffnen" Click="OnOpenPortal" Style="{DynamicResource BpmButtonSecondary}" Foreground="{DynamicResource BpmInfo}" Padding="8,4" FontSize="11" MinWidth="0" MinHeight="0"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Trennlinie -->
                            <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BpmBorderDefault}" Margin="9,0"/>
                            <!-- Rechte Spalte: Eigene Links -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Eigene Links" Style="{StaticResource SH}" Margin="0,0,0,4"/>
                                <TextBlock Text="Projekt-spezifische Links zu SharePoint, LV, Ablagesystemen etc."
                                           Style="{DynamicResource BpmSmallText}" Margin="0,0,0,8"/>
                                <DataGrid x:Name="DgCustomLinks" Style="{StaticResource DgBase}" Height="260"
                                          ColumnHeaderStyle="{StaticResource DgHeaderSecondary}"
                                          CellStyle="{StaticResource DarkDgCell}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Bezeichnung" Binding="{Binding Name}" Width="100"/>
                                        <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource BpmInfo}"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="+ Link" Click="OnAddCustomLink" Style="{DynamicResource BpmButtonPrimary}" Padding="8,4" Margin="0,0,4,0" FontSize="11" MinWidth="0" MinHeight="0"/>
                                    <Button Content="Bearbeiten" Click="OnEditCustomLink" Style="{DynamicResource BpmButtonSecondary}" Padding="8,4" Margin="0,0,4,0" FontSize="11" MinWidth="0" MinHeight="0"/>
                                    <Button Content="Entfernen" Click="OnRemoveCustomLink" Style="{DynamicResource BpmButtonDanger}" Padding="8,4" Margin="0,0,4,0" FontSize="11" MinWidth="0" MinHeight="0"/>
                                    <Button Content="Öffnen" Click="OnOpenCustomLink" Style="{DynamicResource BpmButtonSecondary}" Foreground="{DynamicResource BpmInfo}" Padding="8,4" FontSize="11" MinWidth="0" MinHeight="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <!-- Dashboard-Vorschau -->
                        <Border BorderBrush="{DynamicResource BpmBorderDefault}" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Vorschau im Dashboard" Foreground="{DynamicResource BpmAccentPrimary}" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="So werden die Links im Projekt-Dashboard angezeigt:"
                                           Style="{DynamicResource BpmSmallText}" Margin="0,0,0,8"/>
                                <WrapPanel x:Name="WpLinkPreview"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB 5: ORDNERSTRUKTUR ═══ -->
            <TabItem Header="Ordnerstruktur" Style="{DynamicResource BpmTabItem}">
                <views:FolderTemplateControl x:Name="ProjectFolderTemplate"
                                              Margin="0,8,0,0" />
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Speichern" Click="OnSave"
                    Style="{DynamicResource BpmButtonPrimary}" Padding="20,8" Margin="0,0,10,0"/>
            <Button Content="Abbrechen" Click="OnCancel"
                    Style="{DynamicResource BpmButtonSecondary}" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
