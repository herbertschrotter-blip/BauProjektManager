<UserControl x:Class="BauProjektManager.Settings.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BauProjektManager.Settings.ViewModels">
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <!-- Dark TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="⚙ Einstellungen"
                   FontSize="22" Foreground="#CCCCCC"
                   Margin="0,0,0,10"/>

        <!-- TabControl -->
        <TabControl Grid.Row="1">

            <!-- ═══ TAB 1: PROJEKTE ═══ -->
            <TabItem Header="Projekte">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Projektliste -->
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Background="#252526"
                              Foreground="#CCCCCC"
                              BorderBrush="#3E3E42"
                              RowBackground="#2D2D30"
                              AlternatingRowBackground="#333337"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#3E3E42"
                              HeadersVisibility="Column"
                              CanUserResizeRows="False"
                              MouseDoubleClick="OnRowDoubleClick">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="BorderBrush" Value="#005A9E"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Nr." Binding="{Binding ProjectNumber}" Width="80"/>
                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusConverter}}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Pfad" Binding="{Binding Paths.Root}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#666666"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ Neues Projekt"
                                Command="{Binding AddProjectCommand}"
                                Background="#007ACC" Foreground="White"
                                Padding="15,8" Margin="0,0,10,0"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Bearbeiten"
                                Command="{Binding EditProjectCommand}"
                                Background="#3E3E42" Foreground="#CCCCCC"
                                Padding="15,8" Margin="0,0,10,0"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Archivieren"
                                Background="#3E3E42" Foreground="#CCCCCC"
                                Padding="15,8" Margin="0,0,10,0"
                                BorderThickness="0" Cursor="Hand"
                                IsEnabled="False" ToolTip="Kommt in Feature #12"/>
                        <Button Content="Löschen"
                                Command="{Binding DeleteProjectCommand}"
                                Background="#C62828" Foreground="White"
                                Padding="15,8"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>

                    <!-- Pfade — unten verankert -->
                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <Rectangle Height="1" Fill="#3E3E42" Margin="0,0,0,12"/>
                        <TextBlock Text="── Pfade ──" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Arbeitsordner:"
                                       Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding BasePath, Mode=OneWay}"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="📁"
                                    Background="#3E3E42" Foreground="#CCCCCC"
                                    Padding="8,4" Margin="5,4,0,4"
                                    BorderThickness="0" Cursor="Hand"
                                    IsEnabled="False" ToolTip="Kommt in Feature #13"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Archivordner:"
                                       Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding ArchivePath, Mode=OneWay}"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="📁"
                                    Background="#3E3E42" Foreground="#CCCCCC"
                                    Padding="8,4" Margin="5,4,0,4"
                                    BorderThickness="0" Cursor="Hand"
                                    IsEnabled="False" ToolTip="Kommt in Feature #13"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="OneDrive:"
                                       Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding OneDrivePath, Mode=OneWay}"
                                     Background="#1E1E1E" Foreground="#666666"
                                     BorderBrush="#3E3E42" Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="(auto)" Foreground="#666666"
                                       VerticalAlignment="Center" Margin="5,4,0,4"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: STANDARD-ORDNERSTRUKTUR ═══ -->
            <TabItem Header="Standard-Ordnerstruktur">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Wird als Vorlage bei jedem neuen Projekt verwendet. Beim Anlegen pro Projekt anpassbar."
                               Foreground="#666666" FontSize="11" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Ordner-Baum -->
                        <TreeView x:Name="TvFolders" Grid.Column="0"
                                  ItemsSource="{Binding FolderTreeItems}"
                                  Background="#1E1E1E" Foreground="#CCCCCC"
                                  BorderBrush="#3E3E42" Height="400"
                                  SelectedItemChanged="OnTreeSelectionChanged">
                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Foreground" Value="#CCCCCC"/>
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Padding" Value="2"/>
                                </Style>
                            </TreeView.Resources>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#CCCCCC"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                        <TextBlock Text="  📥" Foreground="#007ACC" FontSize="12"
                                                   Visibility="{Binding InboxVisibility}"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <TextBlock Text="{Binding PrefixLabel}" Foreground="#555555"
                                                   FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <!-- Buttons + Beschreibungen in einem Grid -->
                        <Grid Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,0,0" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="38"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="38"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Content="▲" Click="OnTemplateMoveUp" Width="32" Height="28"
                                    Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Nach oben verschieben"
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="1" Grid.Column="0" Content="▼" Click="OnTemplateMoveDown" Width="32" Height="28"
                                    Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Nach unten verschieben"
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="2" Grid.Column="0" Content="＋" Click="OnTemplateAddMain" Width="32" Height="28"
                                    Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Hauptordner (immer nummeriert)"
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="3" Grid.Column="0" Content="＋└" Click="OnTemplateAddSub" Width="32" Height="28"
                                    Background="#085041" Foreground="#5DCAA5" BorderThickness="0" Cursor="Hand" FontSize="10" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Unterordner zum gewählten Hauptordner"
                                       Foreground="#5DCAA5" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="4" Grid.Column="0" Content="✕" Click="OnTemplateRemove" Width="32" Height="28"
                                    Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Entfernen"
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="5" Grid.Column="0" Content="📥" Click="OnTemplateToggleInbox" Width="32" Height="28"
                                    Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="_Eingang ein/aus"
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="6" Grid.Column="0" Content="##" Click="OnTemplateTogglePrefix" Width="32" Height="28"
                                    Background="#3E3E42" Foreground="#CCCCCC" BorderThickness="0" Cursor="Hand" FontSize="10" FontWeight="Bold" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Präfix ein/aus (nur Unterordner)"
                                       Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <TextBlock Foreground="#555555" FontSize="11">Präfix an: 00 Polierpläne</TextBlock>
                                <TextBlock Foreground="#555555" FontSize="11" Margin="0,2,0,0">Präfix aus: Baustelleneinrichtung</TextBlock>
                                <TextBlock Foreground="#555555" FontSize="11" Margin="0,10,0,0">Änderungen werden sofort gespeichert.</TextBlock>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Statusleiste -->
        <TextBlock Grid.Row="2" Text="{Binding RegistryStatus}"
                   Foreground="#999999" FontSize="11" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
