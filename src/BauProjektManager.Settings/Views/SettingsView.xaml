<UserControl x:Class="BauProjektManager.Settings.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BauProjektManager.Settings.ViewModels">
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <!-- Dark TabControl Style (Token-basiert) -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{DynamicResource BpmFontFamily}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource BpmAccentPrimary}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="⚙ Einstellungen"
                   Style="{DynamicResource BpmHeading1}"/>

        <!-- TabControl -->
        <TabControl Grid.Row="1">

            <!-- ═══ TAB 1: PROJEKTE ═══ -->
            <TabItem Header="Projekte">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Projektliste -->
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}"
                              Style="{DynamicResource BpmDataGridZebra}"
                              ColumnHeaderStyle="{DynamicResource BpmDataGridColumnHeader}"
                              RowStyle="{DynamicResource BpmDataGridRow}"
                              CellStyle="{DynamicResource BpmDataGridCell}"
                              MouseDoubleClick="OnRowDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Nr." Binding="{Binding ProjectNumber}" Width="80"/>
                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusConverter}}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Pfad" Binding="{Binding Paths.Root}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource BpmDataGridCellSecondary}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ Neues Projekt"
                                Command="{Binding AddProjectCommand}"
                                Style="{DynamicResource BpmButtonPrimary}"
                                Margin="0,0,10,0"/>
                        <Button Content="Bearbeiten"
                                Command="{Binding EditProjectCommand}"
                                Style="{DynamicResource BpmButtonSecondary}"
                                Margin="0,0,10,0"/>
                        <Button Content="Archivieren"
                                Style="{DynamicResource BpmButtonSecondary}"
                                Margin="0,0,10,0"
                                IsEnabled="False" ToolTip="Kommt in Feature #12"/>
                        <Button Content="Löschen"
                                Command="{Binding DeleteProjectCommand}"
                                Style="{DynamicResource BpmButtonDanger}"/>
                    </StackPanel>

                    <!-- Pfade — unten verankert -->
                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <Rectangle Height="1" Fill="{DynamicResource BpmBorderDefault}" Margin="0,0,0,12"/>
                        <TextBlock Text="── Pfade ──" Foreground="{DynamicResource BpmAccentPrimary}"
                                   FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Arbeitsordner:"
                                       Style="{DynamicResource BpmBodyText}"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding BasePath, Mode=OneWay}"
                                     Background="{DynamicResource BpmBgBase}"
                                     Foreground="{DynamicResource BpmTextPrimary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="📁"
                                    Click="OnBrowseBasePath"
                                    Style="{DynamicResource BpmButtonGhost}"
                                    Margin="5,4,0,4"
                                    ToolTip="Arbeitsordner wählen"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Archivordner:"
                                       Style="{DynamicResource BpmBodyText}"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding ArchivePath, Mode=OneWay}"
                                     Background="{DynamicResource BpmBgBase}"
                                     Foreground="{DynamicResource BpmTextPrimary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="📁"
                                    Click="OnBrowseArchivePath"
                                    Style="{DynamicResource BpmButtonGhost}"
                                    Margin="5,4,0,4"
                                    ToolTip="Archivordner wählen"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cloud-Speicher:"
                                       Style="{DynamicResource BpmBodyText}"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding OneDrivePath, Mode=OneWay}"
                                     Background="{DynamicResource BpmBgBase}"
                                     Foreground="{DynamicResource BpmTextSecondary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="(auto)"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="5,4,0,4"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: STANDARD-ORDNERSTRUKTUR ═══ -->
            <TabItem Header="Standard-Ordnerstruktur">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Wird als Vorlage bei jedem neuen Projekt verwendet. Beim Anlegen pro Projekt anpassbar."
                               Style="{DynamicResource BpmSmallText}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Ordner-Baum -->
                        <TreeView x:Name="TvFolders" Grid.Column="0"
                                  ItemsSource="{Binding FolderTreeItems}"
                                  Background="{DynamicResource BpmBgBase}"
                                  Foreground="{DynamicResource BpmTextPrimary}"
                                  BorderBrush="{DynamicResource BpmBorderDefault}" Height="400"
                                  SelectedItemChanged="OnTreeSelectionChanged">
                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Padding" Value="2"/>
                                </Style>
                            </TreeView.Resources>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource BpmTextPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                        <TextBlock Text="  📥"
                                                   Foreground="{DynamicResource BpmAccentPrimary}"
                                                   FontSize="12"
                                                   Visibility="{Binding InboxVisibility}"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <TextBlock Text="{Binding PrefixLabel}"
                                                   Foreground="{DynamicResource BpmTextSecondary}"
                                                   FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <!-- Buttons + Beschreibungen in einem Grid -->
                        <Grid Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,0,0" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="38"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="38"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="31"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Content="▲" Click="OnTemplateMoveUp"
                                    Width="32" Height="28"
                                    Style="{DynamicResource BpmButtonSecondary}"
                                    Padding="0" MinWidth="0" MinHeight="0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Nach oben verschieben"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="1" Grid.Column="0" Content="▼" Click="OnTemplateMoveDown"
                                    Width="32" Height="28"
                                    Style="{DynamicResource BpmButtonSecondary}"
                                    Padding="0" MinWidth="0" MinHeight="0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Nach unten verschieben"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="2" Grid.Column="0" Content="＋" Click="OnTemplateAddMain"
                                    Width="32" Height="28"
                                    Style="{DynamicResource BpmButtonPrimary}"
                                    Padding="0" MinWidth="0" MinHeight="0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Hauptordner (immer nummeriert)"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="3" Grid.Column="0" Content="＋└" Click="OnTemplateAddSub"
                                    Width="32" Height="28"
                                    Background="#085041" Foreground="#5DCAA5"
                                    BorderThickness="0" Cursor="Hand" FontSize="10"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Unterordner zum gewählten Hauptordner"
                                       Foreground="#5DCAA5" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="4" Grid.Column="0" Content="✕" Click="OnTemplateRemove"
                                    Width="32" Height="28"
                                    Style="{DynamicResource BpmButtonDanger}"
                                    Padding="0" MinWidth="0" MinHeight="0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Entfernen"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="5" Grid.Column="0" Content="📥" Click="OnTemplateToggleInbox"
                                    Width="32" Height="28"
                                    Style="{DynamicResource BpmButtonSecondary}"
                                    Padding="0" MinWidth="0" MinHeight="0"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="_Eingang ein/aus"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <Button Grid.Row="6" Grid.Column="0" Content="##" Click="OnTemplateTogglePrefix"
                                    Width="32" Height="28"
                                    Style="{DynamicResource BpmButtonSecondary}"
                                    Padding="0" MinWidth="0" MinHeight="0"
                                    FontSize="10" FontWeight="Bold"
                                    VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Präfix ein/aus (nur Unterordner)"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <TextBlock Style="{DynamicResource BpmSmallText}">Präfix an: 00 Polierpläne</TextBlock>
                                <TextBlock Style="{DynamicResource BpmSmallText}" Margin="0,2,0,0">Präfix aus: Baustelleneinrichtung</TextBlock>
                                <TextBlock Style="{DynamicResource BpmSmallText}" Margin="0,10,0,0">Änderungen werden sofort gespeichert.</TextBlock>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Statusleiste -->
        <TextBlock Grid.Row="2" Text="{Binding RegistryStatus}"
                   Style="{DynamicResource BpmSmallText}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
