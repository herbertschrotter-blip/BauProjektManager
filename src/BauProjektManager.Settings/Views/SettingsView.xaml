<UserControl x:Class="BauProjektManager.Settings.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BauProjektManager.Settings.ViewModels">
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="⚙ Einstellungen — Projekte"
                   FontSize="22" Foreground="#CCCCCC"
                   Margin="0,0,0,15"/>

        <!-- Projektliste -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Projects}"
                  SelectedItem="{Binding SelectedProject}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="#252526"
                  Foreground="#CCCCCC"
                  BorderBrush="#3E3E42"
                  RowBackground="#2D2D30"
                  AlternatingRowBackground="#333337"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#3E3E42"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="BorderBrush" Value="#005A9E"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nr." Binding="{Binding ProjectNumber}" Width="80"/>
                <DataGridTextColumn Header="Projekt" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Voller Name" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Gemeinde" Binding="{Binding Location.Municipality}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="+ Neues Projekt"
                    Command="{Binding AddProjectCommand}"
                    Background="#007ACC" Foreground="White"
                    Padding="15,8" Margin="0,0,10,0"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
