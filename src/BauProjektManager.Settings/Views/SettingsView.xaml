<UserControl x:Class="BauProjektManager.Settings.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BauProjektManager.Settings.ViewModels"
             xmlns:views="clr-namespace:BauProjektManager.Settings.Views">
    <UserControl.Resources>
        <!-- Dark TabControl Style (Token-basiert) -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BpmTextSecondary}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{DynamicResource BpmFontFamily}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource BpmAccentPrimary}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BpmTextBright}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BpmTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="⚙ Einstellungen"
                   Style="{DynamicResource BpmHeading1}"/>

        <!-- TabControl -->
        <TabControl Grid.Row="1">

            <!-- ═══ TAB 1: PROJEKTE ═══ -->
            <TabItem Header="Projekte">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Suche + Statusfilter -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Suchfeld mit Platzhalter -->
                        <Grid Grid.Column="0" Margin="0,0,10,0">
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                     Background="{DynamicResource BpmBgSurface}"
                                     Foreground="{DynamicResource BpmTextPrimary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="8,6" FontSize="13"
                                     x:Name="TxtSearch"/>
                            <TextBlock Text="🔍 Suche in Projekten..."
                                       Foreground="{DynamicResource BpmTextSecondary}"
                                       FontSize="13" Padding="10,7"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SearchText, Converter={StaticResource PlaceholderVisibilityConverter}}"/>
                        </Grid>

                        <!-- Statusfilter Toggle-Buttons -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource BpmBgSurface}"
                                CornerRadius="4" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Alle"
                                        Command="{Binding SetFilterAllCommand}"
                                        MinWidth="70" Padding="8,5" FontSize="12"
                                        BorderThickness="0" Cursor="Hand"
                                        x:Name="BtnFilterAll"
                                        Click="OnFilterButtonClick"/>
                                <Button Content="Aktiv"
                                        Command="{Binding SetFilterActiveCommand}"
                                        MinWidth="70" Padding="8,5" FontSize="12"
                                        BorderThickness="0" Cursor="Hand"
                                        x:Name="BtnFilterActive"
                                        Click="OnFilterButtonClick"/>
                                <Button Content="Abgeschlossen"
                                        Command="{Binding SetFilterCompletedCommand}"
                                        MinWidth="70" Padding="8,5" FontSize="12"
                                        BorderThickness="0" Cursor="Hand"
                                        x:Name="BtnFilterCompleted"
                                        Click="OnFilterButtonClick"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Projektliste -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ProjectsView}"
                              SelectedItem="{Binding SelectedProject}"
                              Style="{DynamicResource BpmDataGridZebra}"
                              ColumnHeaderStyle="{DynamicResource BpmDataGridColumnHeader}"
                              RowStyle="{DynamicResource BpmDataGridRow}"
                              CellStyle="{DynamicResource BpmDataGridCell}"
                              MouseDoubleClick="OnRowDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Nr." Binding="{Binding ProjectNumber}" Width="80"/>
                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusConverter}}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Pfad" Binding="{Binding Paths.Root}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource BpmDataGridCellSecondary}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Filter-Info -->
                    <TextBlock Grid.Row="2" Text="{Binding FilterInfo}"
                               Foreground="{DynamicResource BpmTextSecondary}"
                               FontSize="12" Margin="0,4,0,0"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <!-- Neues Projekt — öffnet Popup mit 2 Optionen -->
                        <Button x:Name="BtnNewProject" Content="＋ Neues Projekt"
                                Style="{DynamicResource BpmButtonPrimary}"
                                MinWidth="160" Margin="0,0,10,0"
                                Click="OnNewProjectClick"/>
                        <Popup x:Name="NewProjectPopup"
                               PlacementTarget="{Binding ElementName=BtnNewProject}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{DynamicResource BpmBgSurface}"
                                    BorderBrush="{DynamicResource BpmBorderDefault}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="0,4" MinWidth="220">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.35"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Padding="12,8" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="OnMenuCreateProject"
                                            MouseEnter="OnMenuItemEnter"
                                            MouseLeave="OnMenuItemLeave">
                                        <TextBlock Text="📝 Projekt erstellen"
                                                   Foreground="{DynamicResource BpmTextPrimary}"
                                                   FontSize="13"/>
                                    </Border>
                                    <Rectangle Height="1" Fill="{DynamicResource BpmBorderDefault}" Margin="8,2"/>
                                    <Border Padding="12,8" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="OnMenuImportProject"
                                            MouseEnter="OnMenuItemEnter"
                                            MouseLeave="OnMenuItemLeave">
                                        <TextBlock Text="📂 Projekt importieren"
                                                   Foreground="{DynamicResource BpmTextPrimary}"
                                                   FontSize="13"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Button Content="Bearbeiten"
                                Command="{Binding EditProjectCommand}"
                                Style="{DynamicResource BpmButtonSecondary}"
                                MinWidth="160" Margin="0,0,10,0"/>
                        <Button Content="Archivieren"
                                Style="{DynamicResource BpmButtonSecondary}"
                                MinWidth="160" Margin="0,0,10,0"
                                IsEnabled="False" ToolTip="Kommt in Feature #12"/>
                        <Button Content="Löschen"
                                Command="{Binding DeleteProjectCommand}"
                                Style="{DynamicResource BpmButtonDanger}"
                                MinWidth="160"/>
                    </StackPanel>

                    <!-- Pfade — unten verankert -->
                    <StackPanel Grid.Row="4" Margin="0,20,0,0">
                        <Rectangle Height="1" Fill="{DynamicResource BpmBorderDefault}" Margin="0,0,0,12"/>
                        <TextBlock Text="── Pfade ──" Foreground="{DynamicResource BpmAccentPrimary}"
                                   FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Arbeitsordner:"
                                       Style="{DynamicResource BpmBodyText}"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding BasePath, Mode=OneWay}"
                                     Background="{DynamicResource BpmBgBase}"
                                     Foreground="{DynamicResource BpmTextPrimary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="📁"
                                    Click="OnBrowseBasePath"
                                    Style="{DynamicResource BpmButtonGhost}"
                                    Margin="5,4,0,4"
                                    ToolTip="Arbeitsordner wählen"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Archivordner:"
                                       Style="{DynamicResource BpmBodyText}"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding ArchivePath, Mode=OneWay}"
                                     Background="{DynamicResource BpmBgBase}"
                                     Foreground="{DynamicResource BpmTextPrimary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="📁"
                                    Click="OnBrowseArchivePath"
                                    Style="{DynamicResource BpmButtonGhost}"
                                    Margin="5,4,0,4"
                                    ToolTip="Archivordner wählen"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cloud-Speicher:"
                                       Style="{DynamicResource BpmBodyText}"
                                       VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding OneDrivePath, Mode=OneWay}"
                                     Background="{DynamicResource BpmBgBase}"
                                     Foreground="{DynamicResource BpmTextSecondary}"
                                     BorderBrush="{DynamicResource BpmBorderDefault}"
                                     Padding="5,3" Margin="0,4"
                                     IsReadOnly="True" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="(auto)"
                                       Style="{DynamicResource BpmSmallText}"
                                       VerticalAlignment="Center" Margin="5,4,0,4"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: STANDARD-ORDNERSTRUKTUR ═══ -->
            <TabItem Header="Standard-Ordnerstruktur">
                    <views:FolderTemplateControl x:Name="GlobalFolderTemplate"
                                                  Margin="0,8,0,0" />
                </TabItem>
        </TabControl>

        <!-- Statusleiste -->
        <TextBlock Grid.Row="2" Text="{Binding RegistryStatus}"
                   Style="{DynamicResource BpmSmallText}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
